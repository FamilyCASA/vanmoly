<!-- 我的优惠券 -->
<view class="page">
  <!-- 顶部Tab -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'available' ? 'active' : ''}}" bindtap="switchTab" data-tab="available">
      <text>可使用</text>
      <text class="tab-count" wx:if="{{availableCount > 0}}">{{availableCount}}</text>
    </view>
    <view class="tab-item {{activeTab === 'used' ? 'active' : ''}}" bindtap="switchTab" data-tab="used">
      <text>已使用</text>
    </view>
    <view class="tab-item {{activeTab === 'expired' ? 'active' : ''}}" bindtap="switchTab" data-tab="expired">
      <text>已过期</text>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && currentList.length === 0}}">
    <text class="empty-icon">🎫</text>
    <text class="empty-title">{{activeTab === 'available' ? '暂无可用优惠券' : activeTab === 'used' ? '暂无已使用优惠券' : '暂无过期优惠券'}}</text>
    <text class="empty-desc" wx:if="{{activeTab === 'available'}}">完成装修任务或积分兑换获取优惠券</text>
  </view>

  <!-- 优惠券列表 -->
  <view class="coupon-list" wx:else>
    <view class="coupon-card {{activeTab !== 'available' ? 'disabled' : ''}}" wx:for="{{currentList}}" wx:key="id">
      <view class="cc-left">
        <view class="ccl-amount">
          <text class="ccla-symbol">¥</text>
          <text class="ccla-value">{{item.amount}}</text>
        </view>
        <text class="ccl-condition">{{item.min_amount > 0 ? '满' + item.min_amount + '可用' : '无门槛'}}</text>
      </view>
      <view class="cc-divider"></view>
      <view class="cc-right">
        <text class="ccr-name">{{item.name || item.title}}</text>
        <text class="ccr-scope">{{item.scope || '全品类通用'}}</text>
        <text class="ccr-expire">{{item.expireText}}</text>
        <view class="ccr-use" wx:if="{{activeTab === 'available'}}" catchtap="useCoupon" data-id="{{item.id}}">
          <text>立即使用</text>
        </view>
      </view>
    </view>
  </view>
</view>