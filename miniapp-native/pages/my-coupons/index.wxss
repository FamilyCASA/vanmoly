/* 我的优惠券 */
.page { background: #0a0a1a; min-height: 100vh; }
.tab-bar { display: flex; background: #1a1a2e; padding: 0 24rpx; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.tab-item { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 28rpx 0; position: relative; }
.tab-item text { font-size: 28rpx; color: rgba(255,255,255,0.5); }
.tab-item.active text { color: #D4AF37; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 48rpx; height: 4rpx; background: #D4AF37; border-radius: 2rpx; }
.tab-count { font-size: 20rpx !important; color: #D4AF37 !important; background: rgba(212,175,55,0.12); padding: 2rpx 10rpx; border-radius: 10rpx; }
.loading-wrap { padding: 32rpx; }
.skeleton-card { height: 180rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 20rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); text-align: center; }
.coupon-list { padding: 24rpx; }
.coupon-card { display: flex; background: #1a1a2e; border-radius: 16rpx; overflow: hidden; margin-bottom: 20rpx; border: 1rpx solid rgba(212,175,55,0.15); }
.coupon-card.disabled { opacity: 0.5; border-color: rgba(255,255,255,0.06); }
.cc-left { width: 200rpx; padding: 24rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(212,175,55,0.08); }
.ccl-amount { display: flex; align-items: baseline; }
.ccla-symbol { font-size: 24rpx; color: #D4AF37; font-weight: 600; }
.ccla-value { font-size: 56rpx; color: #D4AF37; font-weight: 700; }
.ccl-condition { font-size: 20rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; }
.cc-divider { width: 2rpx; background: rgba(255,255,255,0.06); position: relative; }
.cc-divider::before, .cc-divider::after { content: ''; position: absolute; left: -8rpx; width: 16rpx; height: 16rpx; background: #0a0a1a; border-radius: 50%; }
.cc-divider::before { top: -8rpx; }
.cc-divider::after { bottom: -8rpx; }
.cc-right { flex: 1; padding: 20rpx 24rpx; display: flex; flex-direction: column; gap: 6rpx; }
.ccr-name { font-size: 28rpx; color: #fff; font-weight: 600; }
.ccr-scope { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.ccr-expire { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.ccr-use { align-self: flex-end; margin-top: 8rpx; padding: 8rpx 20rpx; background: #D4AF37; border-radius: 16rpx; }
.ccr-use text { font-size: 22rpx; color: #0a0a1a; font-weight: 600; }