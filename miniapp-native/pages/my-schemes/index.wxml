<!-- 我的方案 -->
<view class="page">
  <view class="page-header">
    <text class="page-title">我的方案</text>
    <view class="add-btn" bindtap="goCreate" wx:if="{{isLoggedIn}}">
      <text>+ 新建</text>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && schemes.length === 0}}">
    <text class="empty-icon">📐</text>
    <text class="empty-title">暂无方案</text>
    <text class="empty-desc">设计师将根据您的需求定制专属方案</text>
    <view class="empty-btn" bindtap="goCases">
      <text>浏览案例获取灵感</text>
    </view>
  </view>

  <!-- 方案列表 -->
  <view class="scheme-list" wx:else>
    <view class="scheme-card" wx:for="{{schemes}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="sc-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}"/>
      <view class="sc-placeholder" wx:else>
        <text>📐</text>
      </view>
      <view class="sc-info">
        <view class="sc-top">
          <text class="sc-title">{{item.title}}</text>
          <view class="sc-status {{item.status}}">
            <text>{{item.statusText}}</text>
          </view>
        </view>
        <text class="sc-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="sc-meta">
          <text class="scm-item" wx:if="{{item.estate_name}}">{{item.estate_name}}</text>
          <text class="scm-item" wx:if="{{item.designer_name}}">{{item.designer_name}}</text>
        </view>
        <text class="sc-time">更新于 {{item.updatedAt}}</text>
      </view>
    </view>
  </view>
</view>