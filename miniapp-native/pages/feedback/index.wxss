/* 意见反馈 */
.page { background: #0a0a1a; min-height: 100vh; padding-bottom: 140rpx; }
.form-section { padding: 24rpx 32rpx 0; }
.form-label { font-size: 28rpx; color: rgba(255,255,255,0.7); margin-bottom: 16rpx; display: block; }
.type-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.type-item { padding: 12rpx 24rpx; background: #1a1a2e; border-radius: 20rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.type-item text { font-size: 26rpx; color: rgba(255,255,255,0.6); }
.type-item.active { background: rgba(212,175,55,0.12); border-color: rgba(212,175,55,0.3); }
.type-item.active text { color: #D4AF37; }
.textarea { width: 100%; background: #1a1a2e; border: 1rpx solid rgba(255,255,255,0.06); border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; color: #fff; min-height: 200rpx; box-sizing: border-box; }
.char-count { font-size: 22rpx; color: rgba(255,255,255,0.3); text-align: right; display: block; margin-top: 8rpx; }
.image-list { display: flex; gap: 16rpx; flex-wrap: wrap; }
.img-item { position: relative; width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; }
.img-item image { width: 100%; height: 100%; }
.img-delete { position: absolute; top: 4rpx; right: 4rpx; width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.6); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.img-delete text { font-size: 20rpx; color: #fff; }
.img-add { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: rgba(255,255,255,0.04); border: 2rpx dashed rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; }
.img-add text { font-size: 48rpx; color: rgba(255,255,255,0.3); }
.contact-input { background: #1a1a2e; border: 1rpx solid rgba(255,255,255,0.06); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #fff; }
.submit-btn { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom)); background: #0a0a1a; }
.submit-btn view { background: #D4AF37; border-radius: 32rpx; padding: 28rpx 0; text-align: center; }
.submit-btn text { font-size: 30rpx; color: #0a0a1a; font-weight: 600; }