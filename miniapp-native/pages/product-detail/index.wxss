/* 产品详情 - 暗黑深空风格 */
.product-detail-page {
  background: #0a0a1a;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(26,26,46,0.95);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  padding-top: 44px;
  transform: translateY(-100%);
  transition: transform 0.3s;
}

.nav-bar.visible { transform: translateY(0); }

.nav-left, .nav-right {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon { font-size: 48rpx; color: #FFFFFF; font-weight: 300; }
.nav-icon { font-size: 36rpx; color: #FFFFFF; }

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 40rpx;
}

/* 加载状态 */
.loading-screen {
  min-height: 100vh;
  padding: 40px 20px;
}

.skeleton {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 20rpx;
}

.skeleton-image {
  width: 100%;
  height: 600rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-line {
  height: 32rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

/* 图片轮播 */
.image-gallery { position: relative; }

.gallery-swiper { height: 600rpx; }
.gallery-swiper image { width: 100%; height: 100%; }

.image-counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 8rpx 20rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 产品信息 */
.product-info-section {
  background: #1a1a2e;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.sale-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #D4AF37;
}

.market-price {
  font-size: 26rpx;
  color: #606080;
  text-decoration: line-through;
}

.discount-tag {
  padding: 6rpx 16rpx;
  background: rgba(245,34,45,0.15);
  border: 1px solid rgba(245,34,45,0.25);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #ff4d4f;
}

.product-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.product-brand {
  display: block;
  font-size: 24rpx;
  color: #606080;
  margin-bottom: 20rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #A0A0B8;
}

.product-meta {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.meta-item { display: flex; flex-direction: column; gap: 6rpx; }
.meta-label { font-size: 22rpx; color: #606080; }
.meta-value { font-size: 26rpx; color: #E8E8E8; }

/* 规格选择 */
.variant-section {
  background: #1a1a2e;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.variant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.variant-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12rpx;
  min-width: 280rpx;
}

.variant-item.selected {
  border-color: #D4AF37;
  background: rgba(212,175,55,0.08);
}

.variant-item.disabled { opacity: 0.4; }
.variant-item image { width: 80rpx; height: 80rpx; border-radius: 8rpx; }

.variant-info { display: flex; flex-direction: column; gap: 6rpx; }
.variant-name { font-size: 26rpx; color: #E8E8E8; }
.variant-price { font-size: 26rpx; font-weight: 600; color: #D4AF37; }

/* 产品详情 */
.detail-section {
  background: #1a1a2e;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

/* 相关推荐 */
.recommend-section {
  background: #1a1a2e;
  padding: 28rpx 24rpx;
}

.recommend-scroll { white-space: nowrap; }

.recommend-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 16rpx;
}

.recommend-item image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.04);
}

.recommend-name {
  display: block;
  font-size: 24rpx;
  color: #E8E8E8;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-price {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #D4AF37;
}

.bottom-spacer { height: 120rpx; }

/* 底部操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #1a1a2e;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.action-left {
  display: flex;
  gap: 32rpx;
  padding-right: 24rpx;
  border-right: 1px solid rgba(255,255,255,0.08);
}

.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  position: relative;
}

.action-icon .icon { font-size: 40rpx; }
.action-icon .label { font-size: 20rpx; color: #A0A0B8; }

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #D4AF37;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #0a0a1a;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding-left: 24rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #E8E8E8;
}

.qty-btn.disabled { color: #606080; }

.qty-value {
  width: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #FFFFFF;
  border-left: 1px solid rgba(255,255,255,0.12);
  border-right: 1px solid rgba(255,255,255,0.12);
}

.btn-add {
  padding: 18rpx 36rpx;
  background: #D4AF37;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-add text {
  font-size: 28rpx;
  font-weight: 600;
  color: #0a0a1a;
}

.btn-add.adding { background: #52c41a; }

/* 分享弹窗 */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 2000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.share-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.share-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #1a1a2e;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.share-modal.show .share-content { transform: translateY(0); }

.share-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.share-title { font-size: 34rpx; font-weight: 600; color: #FFFFFF; }
.share-close { font-size: 40rpx; color: #606080; }

.share-options {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx 60rpx;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.share-option button {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.share-option button::after { border: none; }

.share-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.share-option text:last-child {
  font-size: 24rpx;
  color: #A0A0B8;
}