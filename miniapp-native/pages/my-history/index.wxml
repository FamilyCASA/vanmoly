<!-- 浏览历史 -->
<view class="page">
  <!-- 顶部 -->
  <view class="page-header">
    <text class="page-title">浏览历史</text>
    <view class="clear-btn" bindtap="clearHistory" wx:if="{{historyList.length > 0}}">
      <text>清空</text>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && historyList.length === 0}}">
    <text class="empty-icon">🕐</text>
    <text class="empty-title">暂无浏览记录</text>
    <text class="empty-desc">浏览过的案例和产品会记录在这里</text>
    <view class="empty-btn" bindtap="goExplore">
      <text>去逛逛</text>
    </view>
  </view>

  <!-- 按日期分组的列表 -->
  <view class="history-list" wx:else>
    <view class="date-group" wx:for="{{historyList}}" wx:key="date">
      <text class="date-label">{{item.date}}</text>
      <view class="history-item" wx:for="{{item.items}}" wx:for-item="h" wx:key="id" bindtap="goToDetail" data-type="{{h.type}}" data-id="{{h.target_id}}">
        <image class="hi-cover" src="{{h.cover}}" mode="aspectFill"/>
        <view class="hi-info">
          <text class="hi-title">{{h.title}}</text>
          <text class="hi-meta">{{h.typeText}}</text>
          <text class="hi-time">{{h.viewTime}}</text>
        </view>
      </view>
    </view>
  </view>
</view>