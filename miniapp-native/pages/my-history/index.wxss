/* 浏览历史 */
.page { background: #0a0a1a; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; background: #1a1a2e; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.clear-btn { padding: 12rpx 24rpx; }
.clear-btn text { font-size: 24rpx; color: rgba(255,255,255,0.4); }
.loading-wrap { padding: 32rpx; }
.skeleton-card { height: 140rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 20rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }
.history-list { padding: 24rpx; }
.date-label { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-bottom: 16rpx; padding-left: 8rpx; display: block; }
.history-item { display: flex; gap: 20rpx; background: #1a1a2e; border-radius: 16rpx; padding: 20rpx; margin-bottom: 12rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.hi-cover { width: 120rpx; height: 90rpx; border-radius: 10rpx; flex-shrink: 0; }
.hi-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.hi-title { font-size: 28rpx; color: #fff; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hi-meta { font-size: 20rpx; color: #D4AF37; }
.hi-time { font-size: 20rpx; color: rgba(255,255,255,0.3); }