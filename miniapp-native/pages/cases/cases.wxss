/* 案例列表页样式 */

.search-bar {
  padding: 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 32rpx;
  color: #999;
  padding: 0 10rpx;
}

/* 筛选标签 */
.filter-scroll {
  white-space: nowrap;
  padding: 10rpx 20rpx;
  background: #fff;
}

.filter-list {
  display: flex;
  gap: 16rpx;
}

.filter-item {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #fff;
}

/* 案例网格 */
.case-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.case-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  position: relative;
}

.case-image-wrap {
  position: relative;
  height: 280rpx;
}

.case-image {
  width: 100%;
  height: 100%;
}

.case-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: linear-gradient(135deg, #DAA520, #B8860B);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.case-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 16rpx 12rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.case-area {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

.case-content {
  padding: 20rpx;
}

.case-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-meta {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.case-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.case-price {
  font-size: 28rpx;
  color: #D2691E;
  font-weight: 600;
}

.case-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999;
}

/* 悬浮留资按钮 */
.case-lead-float {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background: linear-gradient(135deg, #8B4513, #D2691E);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部留资栏 */
.lead-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.lead-bar-left {
  flex: 1;
}

.lead-bar-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.lead-bar-desc {
  font-size: 22rpx;
  color: #999;
}

.lead-bar-btn {
  width: 200rpx;
  height: 72rpx;
  font-size: 26rpx;
  margin: 0;
  padding: 0;
}

/* 浮动按钮 */
.float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 160rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #8B4513, #D2691E);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.4);
  z-index: 999;
  animation: pulse 2s infinite;
}

.float-icon {
  font-size: 40rpx;
}

.float-text {
  font-size: 22rpx;
  margin-top: 4rpx;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}