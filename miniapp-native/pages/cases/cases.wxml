<!-- 案例列表 - 小红书瀑布流 · 杂志封面风格 · 暗黑深空 -->
<view class="page">

  <!-- ========== Hero 精选案例 ========== -->
  <view class="hero-section" wx:if="{{featuredCase}}">
    <swiper class="hero-swiper" autoplay circular interval="4000" duration="600" bindchange="onHeroSlide">
      <swiper-item wx:for="{{heroImages}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill" class="hero-bg"/>
      </swiper-item>
    </swiper>
    <view class="hero-overlay"></view>
    <view class="hero-content">
      <!-- 品牌标识 -->
      <text class="brand-en">DESIGNARY</text>
      <text class="brand-cn">帝标·设记家</text>
      <!-- 氛围标签 -->
      <view class="hero-badge" wx:if="{{featuredCase.atmosphere}}">
        <text>{{featuredCase.atmosphere}}</text>
      </view>
      <!-- 案例标题 -->
      <text class="hero-title">{{featuredCase.title}}</text>
      <text class="hero-subtitle">
        <text wx:if="{{featuredCase.building_name}}">{{featuredCase.building_name}} · </text>
        <text wx:if="{{featuredCase.location}}">{{featuredCase.location}}</text>
        <text wx:if="{{featuredCase.area}}"> · {{featuredCase.area}}m²</text>
        <text wx:if="{{featuredCase.house_type}}"> {{featuredCase.house_type}}</text>
      </text>
      <!-- 价格 -->
      <view class="hero-price" wx:if="{{featuredCase.total_price}}">
        <text class="price-val">¥{{featuredCase._price}}</text>
        <text class="price-unit">万</text>
      </view>
      <!-- 操作按钮 -->
      <view class="hero-actions">
        <view class="btn-primary" bindtap="goToDetail" data-id="{{featuredCase.id}}">
          <text>查看详情</text>
        </view>
        <view class="btn-ghost" bindtap="openSubscribe" data-case="{{featuredCase}}">
          <text>{{featuredCase.is_subscribed ? '已订阅' : '订阅更新'}}</text>
        </view>
      </view>
    </view>
    <!-- 轮播指示器 -->
    <view class="hero-indicators" wx:if="{{heroImages.length > 1}}">
      <view class="dot {{heroIndex === index ? 'active' : ''}}" wx:for="{{heroImages}}" wx:key="index"></view>
    </view>
  </view>

  <!-- ========== 筛选区 ========== -->
  <view class="filter-section">

    <!-- 服务阶段筛选 -->
    <view class="filter-row">
      <text class="filter-label">服务阶段</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-track">
          <view
            class="phase-btn {{selectedPhase === item.key ? 'active' : ''}}"
            wx:for="{{workflowPhases}}"
            wx:key="key"
            bindtap="selectPhase"
            data-key="{{item.key}}"
          >
            <view class="phase-dot" wx:if="{{item.count > 0}}"></view>
            <text>{{item.label}}</text>
            <text class="phase-count" wx:if="{{item.count}}">({{item.count}})</text>
          </view>
          <view class="phase-clear" wx:if="{{selectedPhase}}" bindtap="clearPhaseFilter">
            <text>✕ 清除</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 阶段节点展开面板 -->
    <view class="nodes-panel" wx:if="{{expandedPhase && phaseNodes.length > 0}}" animation="{{nodesPanelAnim}}">
      <scroll-view scroll-x class="nodes-scroll" enhanced show-scrollbar="{{false}}">
        <view class="nodes-track">
          <view
            class="node-chip {{selectedNodeId === item.id ? 'selected' : ''}}"
            wx:for="{{phaseNodes}}"
            wx:key="id"
            bindtap="selectNode"
            data-id="{{item.id}}"
          >
            <text class="node-phase-tag">{{item.phaseTag}}</text>
            <text class="node-name">{{item.node_name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 氛围筛选 -->
    <view class="filter-row">
      <text class="filter-label">空间氛围</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-track">
          <view
            class="atm-btn {{selectedAtmosphere === item.value ? 'active' : ''}}"
            wx:for="{{atmospheres}}"
            wx:key="key"
            style="background:{{selectedAtmosphere === item.value ? item.color : 'rgba(255,255,255,0.05)'}};border-color:{{selectedAtmosphere === item.value ? item.color : 'rgba(255,255,255,0.08)'}};"
            bindtap="selectAtmosphere"
            data-value="{{item.value}}"
          >
            <text style="color:{{selectedAtmosphere === item.value ? item.textColor : '#A0A0B8'}}">{{item.label}}</text>
            <text class="atm-count" wx:if="{{item.count}}" style="color:{{selectedAtmosphere === item.value ? 'rgba(255,255,255,0.8)' : '#606080'}}">{{item.count}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 预算筛选 -->
    <view class="filter-row">
      <text class="filter-label">预算筛选</text>
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-track">
          <view
            class="budget-btn {{selectedBudget && selectedBudget.key === item.key ? 'active' : ''}}"
            wx:for="{{budgetSegments}}"
            wx:key="key"
            bindtap="selectBudget"
            data-seg="{{item}}"
          >
            <text>{{item.label}}</text>
          </view>
          <view class="budget-clear" wx:if="{{selectedBudget}}" bindtap="clearBudgetFilter">
            <text>✕</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 颜色偏好筛选 -->
    <view class="filter-row" wx:if="{{colorPalette.length > 0}}">
      <text class="filter-label">颜色偏好</text>
      <view class="color-grid">
        <view
          class="color-card {{selectedColor === item.hex ? 'active' : ''}}"
          wx:for="{{colorPalette}}"
          wx:key="hex"
          style="background-color:{{item.hex}}"
          bindtap="selectColor"
          data-hex="{{item.hex}}"
        >
          <text class="color-count" wx:if="{{item.count}}">{{item.count}}</text>
        </view>
        <view class="color-clear" wx:if="{{selectedColor}}" bindtap="clearColorFilter">
          <text>✕</text>
        </view>
      </view>
    </view>

  </view>

  <!-- ========== 案例瀑布流 ========== -->
  <view class="section-header">
    <text class="sec-title">精选配置方案</text>
    <text class="sec-sub">每个案例包含多种空间配置方案</text>
  </view>

  <!-- 瀑布流容器：左右两列 -->
  <view class="waterfall" wx:if="{{!loading && cases.length > 0}}">
    <!-- 左列 -->
    <view class="waterfall-col">
      <view
        class="wf-card"
        wx:for="{{leftCol}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="wf-img-wrap">
          <image
            wx:if="{{item.cover_image}}"
            src="{{item.cover_image}}"
            mode="widthFix"
            class="wf-img"
            lazy-load
            binderror="onImgError"
            data-index="{{item._index}}"
            data-side="left"
          />
          <view wx:else class="wf-no-img" style="background:{{item._gradient}}">
            <text>{{item.title}}</text>
          </view>
          <!-- 收藏按钮 -->
          <view class="wf-fav-btn {{item.is_favorited ? 'favorited' : ''}}" catchtap="toggleFavorite" data-id="{{item.id}}">
            <text>{{item.is_favorited ? '♥' : '♡'}}</text>
          </view>
          <!-- 杂志封面覆盖层 -->
          <view class="wf-overlay">
            <view class="wf-atm" wx:if="{{item.atmosphere}}">{{item.atmosphere}}</view>
            <view class="wf-bottom">
              <text class="wf-title">{{item.title}}</text>
              <view class="wf-meta">
                <text wx:if="{{item.house_type}}">{{item.house_type}}</text>
                <text wx:if="{{item.area}}">{{item.area}}m²</text>
                <text wx:if="{{item.city}}">{{item.city}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <!-- 右列 -->
    <view class="waterfall-col">
      <view
        class="wf-card"
        wx:for="{{rightCol}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="wf-img-wrap">
          <image
            wx:if="{{item.cover_image}}"
            src="{{item.cover_image}}"
            mode="widthFix"
            class="wf-img"
            lazy-load
            binderror="onImgError"
            data-index="{{item._index}}"
            data-side="right"
          />
          <view wx:else class="wf-no-img" style="background:{{item._gradient}}">
            <text>{{item.title}}</text>
          </view>
          <!-- 收藏按钮 -->
          <view class="wf-fav-btn {{item.is_favorited ? 'favorited' : ''}}" catchtap="toggleFavorite" data-id="{{item.id}}">
            <text>{{item.is_favorited ? '♥' : '♡'}}</text>
          </view>
          <view class="wf-overlay">
            <view class="wf-atm" wx:if="{{item.atmosphere}}">{{item.atmosphere}}</view>
            <view class="wf-bottom">
              <text class="wf-title">{{item.title}}</text>
              <view class="wf-meta">
                <text wx:if="{{item.house_type}}">{{item.house_type}}</text>
                <text wx:if="{{item.area}}">{{item.area}}m²</text>
                <text wx:if="{{item.city}}">{{item.city}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loader"></view>
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && cases.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无符合条件的案例</text>
    <view class="empty-btn" bindtap="resetAllFilters">
      <text>重置筛选</text>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{!loading && hasMore && cases.length > 0}}" bindtap="loadMore">
    <text>{{loadingMore ? '加载中...' : '查看更多方案'}}</text>
  </view>

  <!-- ========== 订阅弹窗 ========== -->
  <view class="modal-mask" wx:if="{{showSubscribe}}" bindtap="closeSubscribe">
    <view class="modal-box" catchtap="preventBubble">
      <text class="modal-title">订阅案例更新</text>
      <text class="modal-desc">订阅「{{subscribeCase.title}}」后，案例更新时将通知您</text>
      <input
        class="modal-input"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        value="{{subscribePhone}}"
        bindinput="onSubInput"
      />
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="closeSubscribe"><text>取消</text></view>
        <view class="modal-btn confirm {{subscribing ? 'disabled' : ''}}" bindtap="submitSubscribe">
          <text>{{subscribing ? '提交中...' : '确认订阅'}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
