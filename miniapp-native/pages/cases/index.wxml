<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <scroll-view scroll-x class="filter-scroll">
      <view class="filter-list">
        <view class="filter-item {{currentStyle === '' ? 'active' : ''}}" bindtap="filterByStyle" data-style="">全部</view>
        <view class="filter-item {{currentStyle === '现代简约' ? 'active' : ''}}" bindtap="filterByStyle" data-style="现代简约">现代简约</view>
        <view class="filter-item {{currentStyle === '新中式' ? 'active' : ''}}" bindtap="filterByStyle" data-style="新中式">新中式</view>
        <view class="filter-item {{currentStyle === '北欧风' ? 'active' : ''}}" bindtap="filterByStyle" data-style="北欧风">北欧风</view>
        <view class="filter-item {{currentStyle === '轻奢' ? 'active' : ''}}" bindtap="filterByStyle" data-style="轻奢">轻奢</view>
        <view class="filter-item {{currentStyle === '美式' ? 'active' : ''}}" bindtap="filterByStyle" data-style="美式">美式</view>
      </view>
    </scroll-view>
  </view>

  <!-- 案例列表 -->
  <view class="cases-grid">
    <view class="case-item" wx:for="{{cases}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="case-cover" src="{{item.cover_image}}" mode="aspectFill"/>
      <view class="case-overlay">
        <text class="case-title">{{item.title}}</text>
        <text class="case-subtitle">{{item.style}} · {{item.area}}㎡</text>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text bindtap="loadMore">加载更多</text>
  </view>
  <view class="no-more" wx:else>
    <text>没有更多了</text>
  </view>
</view>