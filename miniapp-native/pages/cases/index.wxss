.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.filter-item {
  padding: 12rpx 30rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.filter-item.active {
  color: #fff;
  background: #8B5A2B;
}

/* 案例网格 */
.cases-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.case-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
}

.case-cover {
  width: 100%;
  height: 400rpx;
}

.case-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
}

.case-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.case-subtitle {
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 40rpx;
}

.load-more text {
  color: #8B5A2B;
  font-size: 28rpx;
}

.no-more text {
  color: #999;
  font-size: 26rpx;
}