/* 我的笔记 */
.page { background: #0a0a1a; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; background: #1a1a2e; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.add-btn { padding: 12rpx 24rpx; background: #D4AF37; border-radius: 24rpx; }
.add-btn text { font-size: 24rpx; color: #0a0a1a; font-weight: 600; }
.loading-wrap { padding: 32rpx; }
.skeleton-card { height: 200rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 20rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }
.note-list { padding: 24rpx; }
.note-card {
  display: flex; gap: 20rpx; background: #1a1a2e; border-radius: 16rpx;
  padding: 24rpx; margin-bottom: 20rpx; border: 1rpx solid rgba(255,255,255,0.06);
}
.nc-cover { width: 160rpx; height: 120rpx; border-radius: 12rpx; overflow: hidden; flex-shrink: 0; }
.nc-cover image { width: 100%; height: 100%; }
.nc-content { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.nc-title { font-size: 30rpx; color: #fff; font-weight: 600; }
.nc-excerpt { font-size: 24rpx; color: rgba(255,255,255,0.5); overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.nc-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.nc-tags { display: flex; gap: 8rpx; flex-wrap: wrap; flex: 1; }
.nct-item { font-size: 20rpx; color: #D4AF37; background: rgba(212,175,55,0.12); padding: 2rpx 10rpx; border-radius: 10rpx; }
.nc-time { font-size: 20rpx; color: rgba(255,255,255,0.3); flex-shrink: 0; }
.nc-delete { width: 48rpx; display: flex; align-items: flex-start; justify-content: center; }
.nc-delete text { font-size: 28rpx; color: rgba(255,255,255,0.3); }