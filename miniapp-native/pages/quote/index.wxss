/* 报价列表 - 暗黑深空风格 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.create-btn {
  background: #D4AF37;
  color: #0a0a1a;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
}

.quote-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quote-card {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 28rpx;
}

.qc-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.qc-no {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.qc-status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.qc-status-badge.draft { background: rgba(255,255,255,0.06); color: #A0A0B8; }
.qc-status-badge.sent { background: rgba(24,144,255,0.15); color: #1890ff; }
.qc-status-badge.confirmed { background: rgba(82,196,26,0.15); color: #52c41a; }
.qc-status-badge.signed { background: rgba(82,196,26,0.15); color: #52c41a; }
.qc-status-badge.expired { background: rgba(245,34,45,0.15); color: #ff4d4f; }

.qc-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.qc-row {
  display: flex;
}

.qr-label {
  font-size: 26rpx;
  color: #606080;
  width: 100rpx;
}

.qr-val {
  font-size: 26rpx;
  color: #E8E8E8;
}

.qr-val.amount {
  color: #D4AF37;
  font-weight: 600;
}

.qc-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1px solid rgba(255,255,255,0.04);
}

.qc-creator {
  font-size: 22rpx;
  color: #606080;
}

.qc-actions {
  display: flex;
  gap: 16rpx;
}

.qa-btn {
  padding: 8rpx 20rpx;
  border: 1px solid rgba(212,175,55,0.3);
  border-radius: 20rpx;
}

.qa-btn text {
  font-size: 24rpx;
  color: #D4AF37;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.es-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.es-text {
  font-size: 30rpx;
  color: #606080;
  display: block;
  margin-bottom: 32rpx;
}

.es-btn {
  background: #D4AF37;
  color: #0a0a1a;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
}

.lm-text {
  font-size: 26rpx;
  color: #D4AF37;
}