<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">{{isAdmin ? '报价管理' : '我的报价'}}</text>
    <button class="create-btn" bindtap="createQuote" wx:if="{{isAdmin}}">+ 新建报价</button>
  </view>

  <!-- 报价列表 -->
  <view class="quote-list">
    <view class="quote-card" wx:for="{{quotes}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="quote-header">
        <text class="quote-no">{{item.quote_no}}</text>
        <text class="quote-status {{item.status}}">{{statusText[item.status]}}</text>
      </view>
      <view class="quote-body">
        <view class="info-row">
          <text class="label">客户：</text>
          <text class="value">{{item.customer_name}}</text>
        </view>
        <view class="info-row">
          <text class="label">金额：</text>
          <text class="value amount">¥{{item.total_amount}}</text>
        </view>
        <view class="info-row">
          <text class="label">日期：</text>
          <text class="value">{{item.created_at}}</text>
        </view>
      </view>
      <view class="quote-footer">
        <text class="creator" wx:if="{{isAdmin}}">创建人：{{item.creator_name}}</text>
        <view class="actions">
          <text class="action" bindtap="previewQuote" data-id="{{item.id}}">预览</text>
          <text class="action" bindtap="shareQuote" data-id="{{item.id}}">分享</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{quotes.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无报价单</text>
    <button class="empty-btn" bindtap="createQuote" wx:if="{{isAdmin}}">创建报价</button>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text bindtap="loadMore">加载更多</text>
  </view>
</view>