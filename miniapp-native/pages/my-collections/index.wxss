/* 我的收藏 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #1a1a2e;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  position: relative;
}
.tab-item text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
}
.tab-item.active text {
  color: #D4AF37;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #D4AF37;
  border-radius: 2rpx;
}
.tab-count {
  font-size: 20rpx !important;
  color: #D4AF37 !important;
  background: rgba(212,175,55,0.12);
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 500 !important;
}

/* 加载态 */
.loading-wrap { padding: 32rpx; }
.skeleton-card {
  height: 160rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  animation: skeleton 1.5s infinite;
}
@keyframes skeleton {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 0.3; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }

/* 收藏列表 */
.collection-list { padding: 24rpx; }

/* 案例卡片 */
.case-card {
  display: flex;
  gap: 20rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.cc-cover { width: 180rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; }
.cc-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.cc-title { font-size: 28rpx; color: #fff; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cc-meta { display: flex; gap: 12rpx; }
.ccm-item { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.cc-time { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.cc-delete { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; }
.cc-delete text { font-size: 28rpx; color: rgba(255,255,255,0.3); }

/* 产品卡片 */
.product-card {
  display: flex;
  gap: 20rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.pc-cover { width: 120rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; }
.pc-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.pc-brand { font-size: 20rpx; color: #D4AF37; }
.pc-name { font-size: 28rpx; color: #fff; font-weight: 500; }
.pc-price { font-size: 26rpx; color: #FF6B6B; font-weight: 600; }
.pc-delete { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; }
.pc-delete text { font-size: 28rpx; color: rgba(255,255,255,0.3); }

/* 设计师卡片 */
.designer-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.dc-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; flex-shrink: 0; }
.dc-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.dc-name { font-size: 30rpx; color: #fff; font-weight: 600; }
.dc-title { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.dc-tags { display: flex; gap: 8rpx; margin-top: 4rpx; }
.dct-item { font-size: 20rpx; color: #D4AF37; background: rgba(212,175,55,0.12); padding: 2rpx 10rpx; border-radius: 10rpx; }
.dc-unfollow { padding: 12rpx 20rpx; background: rgba(255,255,255,0.06); border-radius: 20rpx; }
.dc-unfollow text { font-size: 22rpx; color: rgba(255,255,255,0.5); }