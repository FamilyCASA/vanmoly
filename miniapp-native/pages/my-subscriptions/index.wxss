/* 我的订阅 */
.page { background: #0a0a1a; min-height: 100vh; padding-bottom: 80rpx; }
.page-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; background: #1a1a2e; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.action-btn { padding: 12rpx 24rpx; background: rgba(212,175,55,0.15); border: 1rpx solid rgba(212,175,55,0.3); border-radius: 24rpx; }
.action-btn text { font-size: 24rpx; color: #D4AF37; font-weight: 500; }
.loading-wrap { padding: 32rpx; }
.skeleton-card { height: 160rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 20rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }
.sub-list { padding: 24rpx; }
.sub-card { display: flex; gap: 20rpx; background: #1a1a2e; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.sc-cover { width: 180rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; }
.sc-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.sc-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12rpx; }
.sc-title { font-size: 28rpx; color: #fff; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sc-status { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 10rpx; flex-shrink: 0; }
.sc-status.active { background: rgba(103,194,58,0.12); }
.sc-status.active text { color: #67C23A; }
.sc-status.paused { background: rgba(255,255,255,0.06); }
.sc-status.paused text { color: rgba(255,255,255,0.5); }
.sc-meta { display: flex; gap: 12rpx; flex-wrap: wrap; }
.scm-item { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.sc-time { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.sc-toggle { display: flex; align-items: center; padding: 8rpx 16rpx; background: rgba(255,255,255,0.06); border-radius: 20rpx; flex-shrink: 0; align-self: center; }
.sc-toggle text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.bottom-tip { text-align: center; padding: 24rpx; }
.bottom-tip text { font-size: 22rpx; color: rgba(255,255,255,0.3); }