/* 我的预约 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #1a1a2e;
  padding: 0 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  position: relative;
}
.tab-item text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}
.tab-item.active text {
  color: #D4AF37;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #D4AF37;
  border-radius: 2rpx;
}
.tab-dot {
  width: 12rpx; height: 12rpx;
  background: #FF6B6B;
  border-radius: 50%;
}

/* 加载态 */
.loading-wrap { padding: 32rpx; }
.skeleton-card {
  height: 200rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  animation: skeleton 1.5s infinite;
}
@keyframes skeleton {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 0.3; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }

/* 预约卡片 */
.appointment-list { padding: 24rpx; }
.appointment-card {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.ac-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.ac-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}
.ac-status.pending { background: rgba(212,175,55,0.12); }
.ac-status.pending text { color: #D4AF37; }
.ac-status.confirmed { background: rgba(100,149,237,0.12); }
.ac-status.confirmed text { color: #6495ED; }
.ac-status.completed { background: rgba(103,194,58,0.12); }
.ac-status.completed text { color: #67C23A; }
.ac-status.cancelled { background: rgba(255,255,255,0.06); }
.ac-status.cancelled text { color: rgba(255,255,255,0.5); }
.ac-time { font-size: 22rpx; color: rgba(255,255,255,0.4); }

.ac-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.ac-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.acr-label { font-size: 26rpx; color: rgba(255,255,255,0.5); }
.acr-value { font-size: 26rpx; color: rgba(255,255,255,0.8); }
.acr-value.highlight { color: #D4AF37; font-weight: 600; }

.ac-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.aca-btn {
  flex: 1;
  padding: 16rpx 0;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  text-align: center;
}
.aca-btn text { font-size: 26rpx; color: rgba(255,255,255,0.7); }
.aca-btn.primary { background: #D4AF37; }
.aca-btn.primary text { color: #0a0a1a; font-weight: 600; }

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #1a1a2e;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.create-btn {
  background: #D4AF37;
  border-radius: 32rpx;
  padding: 24rpx 0;
  text-align: center;
}
.create-btn text { font-size: 30rpx; color: #0a0a1a; font-weight: 600; }