/* 我的订单 */
.page { background: #0a0a1a; min-height: 100vh; padding-bottom: 40rpx; }
.tab-bar { display: flex; background: #1a1a2e; padding: 0 8rpx; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.tab-item { flex: 1; display: flex; align-items: center; justify-content: center; padding: 28rpx 0; position: relative; }
.tab-item text { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.tab-item.active text { color: #D4AF37; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 36rpx; height: 4rpx; background: #D4AF37; border-radius: 2rpx; }
.loading-wrap { padding: 32rpx; }
.skeleton-card { height: 240rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 20rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }
.order-list { padding: 24rpx; }
.order-card { background: #1a1a2e; border-radius: 16rpx; margin-bottom: 20rpx; border: 1rpx solid rgba(255,255,255,0.06); overflow: hidden; }
.oc-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.och-no { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.och-status { font-size: 24rpx; color: #D4AF37; font-weight: 600; }
.och-status.completed { color: #67C23A; }
.och-status.cancelled, .och-status.refunded { color: rgba(255,255,255,0.5); }
.oc-items { padding: 16rpx 24rpx; }
.oci-row { display: flex; align-items: center; gap: 16rpx; padding: 12rpx 0; }
.oci-img { width: 100rpx; height: 100rpx; border-radius: 10rpx; flex-shrink: 0; }
.oci-info { flex: 1; min-width: 0; }
.oci-name { font-size: 26rpx; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }
.oci-spec { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; }
.oci-price { text-align: right; flex-shrink: 0; }
.ocip-val { font-size: 26rpx; color: #fff; display: block; }
.ocip-qty { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; }
.oc-footer { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 24rpx; border-top: 1rpx solid rgba(255,255,255,0.04); }
.ocf-total { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.ocf-total .highlight { color: #D4AF37; font-weight: 600; }
.ocf-actions { display: flex; gap: 12rpx; }
.oca-btn { padding: 10rpx 24rpx; background: rgba(255,255,255,0.06); border-radius: 20rpx; }
.oca-btn text { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.oca-btn.primary { background: #D4AF37; }
.oca-btn.primary text { color: #0a0a1a; font-weight: 600; }