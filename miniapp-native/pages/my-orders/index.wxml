<!-- 我的订单 -->
<view class="page">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all"><text>全部</text></view>
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending"><text>待付款</text></view>
    <view class="tab-item {{activeTab === 'paid' ? 'active' : ''}}" bindtap="switchTab" data-tab="paid"><text>待发货</text></view>
    <view class="tab-item {{activeTab === 'shipped' ? 'active' : ''}}" bindtap="switchTab" data-tab="shipped"><text>待收货</text></view>
    <view class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed"><text>已完成</text></view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}"><view class="skeleton-card"></view><view class="skeleton-card"></view></view>

  <view class="empty-state" wx:elif="{{!loading && orders.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">购买的产品将在这里展示</text>
    <view class="empty-btn" bindtap="goProducts"><text>去选购</text></view>
  </view>

  <view class="order-list" wx:else>
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="oc-header">
        <text class="och-no">订单号：{{item.order_no}}</text>
        <text class="och-status {{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="oc-items" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="oci-row" wx:for="{{item.items}}" wx:for-item="prod" wx:key="id">
          <image class="oci-img" src="{{prod.cover}}" mode="aspectFill"/>
          <view class="oci-info">
            <text class="oci-name">{{prod.name}}</text>
            <text class="oci-spec" wx:if="{{prod.spec}}">{{prod.spec}}</text>
          </view>
          <view class="oci-price">
            <text class="ocip-val">¥{{prod.price}}</text>
            <text class="ocip-qty">x{{prod.quantity}}</text>
          </view>
        </view>
      </view>
      <view class="oc-footer">
        <text class="ocf-total">合计：<text class="highlight">¥{{item.total_amount}}</text></text>
        <view class="ocf-actions">
          <view class="oca-btn" wx:if="{{item.status === 'pending'}}" catchtap="cancelOrder" data-id="{{item.id}}"><text>取消</text></view>
          <view class="oca-btn primary" wx:if="{{item.status === 'pending'}}" catchtap="payOrder" data-id="{{item.id}}"><text>去付款</text></view>
          <view class="oca-btn primary" wx:if="{{item.status === 'shipped'}}" catchtap="confirmReceive" data-id="{{item.id}}"><text>确认收货</text></view>
        </view>
      </view>
    </view>
  </view>
</view>