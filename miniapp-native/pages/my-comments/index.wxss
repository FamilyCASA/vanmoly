/* 我的评论 */
.page { background: #0a0a1a; min-height: 100vh; }
.page-header { padding: 32rpx; background: #1a1a2e; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.loading-wrap { padding: 32rpx; }
.skeleton-card { height: 220rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 20rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 32rpx; text-align: center; }
.empty-btn { padding: 20rpx 48rpx; background: #D4AF37; border-radius: 32rpx; }
.empty-btn text { font-size: 28rpx; color: #0a0a1a; font-weight: 600; }
.comment-list { padding: 24rpx; }
.comment-card { background: #1a1a2e; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.cc-source { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.ccs-label { font-size: 22rpx; color: rgba(255,255,255,0.4); flex-shrink: 0; }
.ccs-title { font-size: 26rpx; color: #D4AF37; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cc-content { margin-bottom: 16rpx; }
.ccc-text { font-size: 28rpx; color: rgba(255,255,255,0.85); line-height: 1.6; }
.ccc-images { display: flex; gap: 12rpx; margin-top: 16rpx; flex-wrap: wrap; }
.ccc-images image { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.cc-bottom { display: flex; align-items: center; gap: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.04); }
.ccb-time { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.ccb-stats { display: flex; gap: 20rpx; margin-left: auto; }
.ccb-stat { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; color: rgba(255,255,255,0.5); }
.ccb-icon { font-size: 26rpx; }
.ccb-delete { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.ccb-delete text { font-size: 22rpx; color: rgba(255,255,255,0.3); }