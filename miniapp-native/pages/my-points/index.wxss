/* 我的积分 */
.page { background: #0a0a1a; min-height: 100vh; }
.points-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #2a2a4e 100%);
  padding: 60rpx 40rpx 48rpx; text-align: center;
}
.ph-label { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 12rpx; }
.ph-value { font-size: 80rpx; font-weight: 700; color: #D4AF37; }
.ph-row { display: flex; justify-content: center; gap: 80rpx; margin-top: 32rpx; }
.ph-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.phi-value { font-size: 32rpx; font-weight: 600; color: #67C23A; }
.phi-value.negative { color: #FF6B6B; }
.phi-label { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.action-row { display: flex; padding: 24rpx; gap: 16rpx; }
.action-item { flex: 1; background: #1a1a2e; border-radius: 16rpx; padding: 24rpx 0; display: flex; flex-direction: column; align-items: center; gap: 8rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.ai-icon { font-size: 40rpx; }
.ai-name { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.section-title { padding: 24rpx 32rpx 16rpx; }
.section-title text { font-size: 30rpx; font-weight: 600; color: #fff; }
.loading-wrap { padding: 24rpx; }
.skeleton-card { height: 80rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; margin-bottom: 12rpx; animation: skeleton 1.5s infinite; }
@keyframes skeleton { 0%,100%{opacity:.6} 50%{opacity:.3} }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 48rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 600; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); text-align: center; }
.record-list { padding: 0 24rpx; }
.record-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.record-item:last-child { border-bottom: none; }
.ri-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.ri-title { font-size: 28rpx; color: rgba(255,255,255,0.85); }
.ri-time { font-size: 22rpx; color: rgba(255,255,255,0.3); }
.ri-value { font-size: 32rpx; font-weight: 600; }
.ri-value.gain { color: #67C23A; }
.ri-value.used { color: #FF6B6B; }