/* 选品清单 - 暗黑深空风格 */
.selection-page {
  background: #0a0a1a;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #1a1a2e;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.header-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32px;
  color: #E8E8E8;
  font-weight: 300;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.header-right {
  width: 88rpx;
  text-align: right;
}

.edit-btn {
  font-size: 26rpx;
  color: #D4AF37;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #E8E8E8;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #A0A0B8;
  margin-bottom: 40rpx;
}

.btn-primary {
  padding: 24rpx 60rpx;
  background: #D4AF37;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #0a0a1a;
  font-weight: 600;
}

/* 选品列表 */
.selection-list {
  flex: 1;
  padding: 20rpx 24rpx;
}

/* 方案信息 */
.scheme-section {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.scheme-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scheme-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8E8E8;
}

.scheme-toggle {
  font-size: 24rpx;
  color: #D4AF37;
}

.scheme-form {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child { margin-bottom: 0; }

.form-label {
  display: block;
  font-size: 24rpx;
  color: #A0A0B8;
  margin-bottom: 10rpx;
}

.form-item input,
.form-item textarea {
  width: 100%;
  padding: 20rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #E8E8E8;
  box-sizing: border-box;
}

.form-item textarea { height: 160rpx; }

.picker-value {
  padding: 20rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #606080;
}

.scheme-preview {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.preview-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.preview-meta {
  font-size: 24rpx;
  color: #606080;
}

/* 分类分组 */
.category-group {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.category-count {
  font-size: 24rpx;
  color: #606080;
}

/* 选品项 */
.selection-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.selection-item:last-child { border-bottom: none; }

.item-checkbox { width: 48rpx; height: 48rpx; }

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2px solid rgba(255,255,255,0.20);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #0a0a1a;
}

.checkbox.checked {
  background: #D4AF37;
  border-color: #D4AF37;
}

.item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.05);
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-variant {
  display: block;
  font-size: 22rpx;
  color: #606080;
  margin-bottom: 10rpx;
}

.item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #D4AF37;
}

.item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #E8E8E8;
}

.qty-btn.disabled { color: #606080; }

.qty-value {
  width: 60rpx;
  text-align: center;
  font-size: 26rpx;
  color: #FFFFFF;
  border-left: 1px solid rgba(255,255,255,0.12);
  border-right: 1px solid rgba(255,255,255,0.12);
}

.item-total {
  font-size: 26rpx;
  font-weight: 600;
  color: #A0A0B8;
}

.delete-btn {
  padding: 10rpx 20rpx;
  background: rgba(245,34,45,0.15);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ff4d4f;
}

/* 价格汇总 */
.summary-section {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #A0A0B8;
}

.summary-row:last-child {
  margin-bottom: 0;
  padding-top: 16rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.summary-row.total {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.total-price {
  font-size: 36rpx;
  color: #D4AF37;
  font-weight: 700;
}

.bottom-spacer { height: 160rpx; }

/* 底部操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #1a1a2e;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.edit-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #A0A0B8;
}

.btn-delete {
  padding: 16rpx 36rpx;
  background: #ff4d4f;
  border: none;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
}

.normal-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.total-label {
  font-size: 26rpx;
  color: #A0A0B8;
}

.total-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #D4AF37;
}

.btn-submit {
  padding: 20rpx 48rpx;
  background: #D4AF37;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #0a0a1a;
  font-weight: 600;
}

/* 成功弹窗 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.75);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.success-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.success-content {
  background: #1a1a2e;
  border: 1px solid rgba(212,175,55,0.25);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  width: 560rpx;
}

.success-icon {
  display: block;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  border-radius: 50%;
  margin: 0 auto 28rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 120rpx;
}

.success-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.success-desc {
  display: block;
  font-size: 26rpx;
  color: #A0A0B8;
  margin-bottom: 32rpx;
}