/* 选品清单页 */
.selection-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.header-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 20px;
  color: #333;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 44px;
  text-align: right;
}

.edit-btn {
  font-size: 14px;
  color: #8B5A2B;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 20px;
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 14px;
  color: #999;
  margin-bottom: 24px;
}

.btn-primary {
  padding: 14px 40px;
  background: #8B5A2B;
  border: none;
  border-radius: 24px;
  font-size: 15px;
  color: #fff;
  font-weight: 500;
}

/* 选品列表 */
.selection-list {
  flex: 1;
  padding: 12px;
}

/* 方案信息 */
.scheme-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.scheme-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scheme-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.scheme-toggle {
  font-size: 13px;
  color: #8B5A2B;
}

.scheme-form {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid #f0f0f0;
}

.form-item {
  margin-bottom: 16px;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.form-item input,
.form-item textarea {
  width: 100%;
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-item textarea {
  height: 80px;
}

.picker-value {
  padding: 12px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
}

.scheme-preview {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.preview-name {
  display: block;
  font-size: 16px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.preview-meta {
  font-size: 13px;
  color: #999;
}

/* 分类分组 */
.category-group {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.category-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.category-count {
  font-size: 13px;
  color: #999;
}

/* 选品项 */
.selection-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.selection-item:last-child {
  border-bottom: none;
}

.item-checkbox {
  width: 24px;
  height: 24px;
}

.checkbox {
  width: 20px;
  height: 20px;
  border: 2px solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #fff;
}

.checkbox.checked {
  background: #8B5A2B;
  border-color: #8B5A2B;
}

.item-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  background: #f5f5f5;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-variant {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.item-price {
  font-size: 15px;
  font-weight: 600;
  color: #8B5A2B;
}

.item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 1px solid #e0e0e0;
  border-radius: 4px;
}

.qty-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #333;
}

.qty-btn.disabled {
  color: #ccc;
}

.qty-value {
  width: 32px;
  text-align: center;
  font-size: 13px;
  color: #333;
  border-left: 1px solid #e0e0e0;
  border-right: 1px solid #e0e0e0;
}

.item-total {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.delete-btn {
  padding: 6px 12px;
  background: #ff4d4f;
  border-radius: 4px;
  font-size: 12px;
  color: #fff;
}

/* 价格汇总 */
.summary-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  font-size: 14px;
  color: #666;
}

.summary-row:last-child {
  margin-bottom: 0;
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.summary-row.total {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.total-price {
  font-size: 20px;
  color: #8B5A2B;
}

.bottom-spacer {
  height: 100px;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1px solid #f0f0f0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  z-index: 100;
}

.edit-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: #666;
}

.btn-delete {
  padding: 10px 24px;
  background: #ff4d4f;
  border: none;
  border-radius: 20px;
  font-size: 14px;
  color: #fff;
}

.normal-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.total-label {
  font-size: 14px;
  color: #666;
}

.total-amount {
  font-size: 22px;
  font-weight: 700;
  color: #8B5A2B;
}

.btn-submit {
  padding: 12px 32px;
  background: #8B5A2B;
  border: none;
  border-radius: 24px;
  font-size: 15px;
  color: #fff;
  font-weight: 500;
}

/* 成功弹窗 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.success-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.success-content {
  background: #fff;
  border-radius: 16px;
  padding: 40px;
  text-align: center;
  width: 280px;
}

.success-icon {
  display: block;
  width: 60px;
  height: 60px;
  background: #52c41a;
  border-radius: 50%;
  margin: 0 auto 20px;
  font-size: 32px;
  color: #fff;
  line-height: 60px;
}

.success-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.success-desc {
  display: block;
  font-size: 14px;
  color: #999;
  margin-bottom: 24px;
}
