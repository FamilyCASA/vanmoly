<!-- 我的合同 -->
<view class="page">
  <view class="page-header">
    <text class="page-title">我的合同</text>
  </view>

  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && contracts.length === 0}}">
    <text class="empty-icon">📄</text>
    <text class="empty-title">暂无合同</text>
    <text class="empty-desc">与设计师确认方案后将生成装修合同</text>
  </view>

  <!-- 合同列表 -->
  <view class="contract-list" wx:else>
    <view class="contract-card" wx:for="{{contracts}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="cc-header">
        <text class="cch-title">{{item.title || item.contract_no}}</text>
        <view class="cch-status {{item.status}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>
      <view class="cc-info">
        <view class="cci-row">
          <text class="cci-label">合同编号</text>
          <text class="cci-value">{{item.contract_no || '-'}}</text>
        </view>
        <view class="cci-row">
          <text class="cci-label">合同金额</text>
          <text class="cci-value highlight">¥{{item.total_amount || 0}}</text>
        </view>
        <view class="cci-row">
          <text class="cci-label">签约日期</text>
          <text class="cci-value">{{item.signDate}}</text>
        </view>
        <view class="cci-row">
          <text class="cci-label">关联房产</text>
          <text class="cci-value">{{item.estate_name || '-'}}</text>
        </view>
      </view>
      <view class="cc-footer">
        <text class="ccf-progress" wx:if="{{item.progress}}">{{item.progress}}</text>
      </view>
    </view>
  </view>
</view>