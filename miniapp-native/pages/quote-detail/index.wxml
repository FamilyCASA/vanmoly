<!-- 报价详情 - 暗黑深空风格 -->
<view class="page">

  <!-- 报价头部 -->
  <view class="quote-header">
    <view class="qh-top">
      <text class="qh-no">{{quote.quote_no}}</text>
      <view class="qh-badge {{quote.status}}">
        <text>{{statusText[quote.status]}}</text>
      </view>
    </view>
  </view>

  <!-- 客户信息 -->
  <view class="info-card">
    <text class="ic-title">客户信息</text>
    <view class="ic-rows">
      <view class="ic-row">
        <text class="ic-label">客户姓名</text>
        <text class="ic-val">{{quote.customer_name}}</text>
      </view>
      <view class="ic-row">
        <text class="ic-label">联系电话</text>
        <text class="ic-val">{{quote.customer_phone}}</text>
      </view>
      <view class="ic-row" wx:if="{{quote.customer_address}}">
        <text class="ic-label">房屋地址</text>
        <text class="ic-val">{{quote.customer_address}}</text>
      </view>
    </view>
  </view>

  <!-- 物料清单 -->
  <view class="info-card">
    <text class="ic-title">物料清单</text>
    <view class="items-list">
      <view class="item-row" wx:for="{{quote.items}}" wx:key="id">
        <view class="ir-top">
          <text class="ir-name">{{item.name}}</text>
          <text class="ir-total">¥{{item.total_price}}</text>
        </view>
        <view class="ir-tags">
          <text class="ir-tag">{{item.room_name}}</text>
          <text class="ir-meta">{{item.spec}}</text>
          <text class="ir-meta">{{item.quantity}}{{item.unit}}</text>
          <text class="ir-meta">¥{{item.unit_price}}/{{item.unit}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 费用汇总 -->
  <view class="info-card">
    <text class="ic-title">费用汇总</text>
    <view class="summary-rows">
      <view class="sr-row">
        <text class="sr-label">小计</text>
        <text class="sr-val">¥{{quote.subtotal}}</text>
      </view>
      <view class="sr-row">
        <text class="sr-label">管理费 ({{quote.management_fee_rate}}%)</text>
        <text class="sr-val">¥{{quote.management_fee}}</text>
      </view>
      <view class="sr-row">
        <text class="sr-label">税费 ({{quote.tax_rate}}%)</text>
        <text class="sr-val">¥{{quote.tax}}</text>
      </view>
      <view class="sr-row total">
        <text class="sr-label">总价</text>
        <text class="sr-val">¥{{quote.total_amount}}</text>
      </view>
    </view>
  </view>

  <!-- 签名区域 -->
  <view class="info-card" wx:if="{{quote.status === 'signed'}}">
    <text class="ic-title">签字确认</text>
    <view class="sig-row" wx:if="{{quote.signature_customer}}">
      <text class="sig-lbl">客户签名</text>
      <image src="{{quote.signature_customer}}" mode="aspectFit" class="sig-img"/>
    </view>
    <view class="sig-row" wx:if="{{quote.signature_planner}}">
      <text class="sig-lbl">规划师签名</text>
      <image src="{{quote.signature_planner}}" mode="aspectFit" class="sig-img"/>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="ab-btn" bindtap="goBack"><text>返回</text></view>
    <view class="ab-btn primary" bindtap="signQuote" wx:if="{{quote.status !== 'signed'}}">
      <text>签字确认</text>
    </view>
    <view class="ab-btn primary" bindtap="shareQuote" wx:else>
      <text>分享报价</text>
    </view>
  </view>

</view>