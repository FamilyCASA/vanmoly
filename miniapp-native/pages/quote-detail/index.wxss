.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 报价头部 */
.quote-header {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quote-no {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.quote-status {
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
}

.quote-status.draft {
  background: #f5f5f5;
  color: #666;
}

.quote-status.sent {
  background: #e6f7ff;
  color: #1890ff;
}

.quote-status.confirmed {
  background: #f6ffed;
  color: #52c41a;
}

.quote-status.signed {
  background: #f6ffed;
  color: #52c41a;
}

/* 区块样式 */
.section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
}

/* 物料列表 */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item-card {
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.item-total {
  font-size: 30rpx;
  font-weight: bold;
  color: #f5222d;
}

.item-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.item-info text {
  font-size: 26rpx;
  color: #666;
}

.item-room {
  background: rgba(139, 90, 43, 0.1);
  color: #8B5A2B !important;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

/* 费用汇总 */
.summary-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
}

.summary-item.total {
  padding-top: 20rpx;
  border-top: 2rpx solid #f5f5f5;
}

.summary-item.total .label,
.summary-item.total .value {
  font-size: 32rpx;
  font-weight: bold;
  color: #f5222d;
}

/* 签名区域 */
.signature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.signature-item {
  background: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
}

.sig-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.signature-item image {
  width: 100%;
  height: 200rpx;
  background: #fff;
  border-radius: 8rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #333;
  border: none;
}

.action-btn.primary {
  background: #8B5A2B;
  color: #fff;
}