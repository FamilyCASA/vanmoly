/* 报价详情 - 暗黑深空风格 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
}

.quote-header {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.qh-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qh-no {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.qh-badge {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.qh-badge.draft { background: rgba(255,255,255,0.06); color: #A0A0B8; }
.qh-badge.sent { background: rgba(24,144,255,0.15); color: #1890ff; }
.qh-badge.confirmed { background: rgba(82,196,26,0.15); color: #52c41a; }
.qh-badge.signed { background: rgba(82,196,26,0.15); color: #52c41a; }

.info-card {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.ic-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8E8E8;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.ic-rows {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ic-row {
  display: flex;
  justify-content: space-between;
}

.ic-label {
  font-size: 26rpx;
  color: #606080;
}

.ic-val {
  font-size: 26rpx;
  color: #E8E8E8;
}

.items-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-row {
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
  padding: 20rpx;
}

.ir-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.ir-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.ir-total {
  font-size: 28rpx;
  font-weight: 600;
  color: #D4AF37;
}

.ir-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ir-tag {
  font-size: 22rpx;
  color: #D4AF37;
  background: rgba(212,175,55,0.10);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.ir-meta {
  font-size: 22rpx;
  color: #606080;
}

.summary-rows {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sr-row {
  display: flex;
  justify-content: space-between;
}

.sr-label {
  font-size: 26rpx;
  color: #A0A0B8;
}

.sr-val {
  font-size: 26rpx;
  color: #E8E8E8;
}

.sr-row.total {
  padding-top: 20rpx;
  border-top: 1px solid rgba(255,255,255,0.08);
}

.sr-row.total .sr-label,
.sr-row.total .sr-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #D4AF37;
}

.sig-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.sig-row:last-child { margin-bottom: 0; }

.sig-lbl {
  font-size: 24rpx;
  color: #A0A0B8;
}

.sig-img {
  width: 100%;
  height: 180rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #1a1a2e;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 16rpx;
  z-index: 100;
}

.ab-btn {
  flex: 1;
  height: 80rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ab-btn text {
  font-size: 28rpx;
  color: #A0A0B8;
}

.ab-btn.primary {
  background: #D4AF37;
}

.ab-btn.primary text {
  color: #0a0a1a;
  font-weight: 600;
}