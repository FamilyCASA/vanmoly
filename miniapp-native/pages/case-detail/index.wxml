<view class="case-detail-page">
  <!-- 固定导航栏（滚动后显示） -->
  <view class="fixed-nav {{showFixedNav ? 'visible' : ''}}">
    <view class="nav-container">
      <view class="nav-left" bindtap="goBack">
        <text class="back-icon">←</text>
        <text class="nav-title">{{caseDetail.title || '案例详情'}}</text>
      </view>
      <view class="nav-right">
        <text class="nav-icon {{isLiked ? 'active' : ''}}" bindtap="handleLike">★</text>
        <text class="nav-icon" bindtap="handleShare">⎋</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-screen">
    <view class="skeleton">
      <view class="skeleton-line" style="height: 400px;"></view>
      <view class="skeleton-line" style="width: 60%; margin-top: 20px;"></view>
      <view class="skeleton-line" style="width: 40%; margin-top: 10px;"></view>
    </view>
  </view>

  <!-- 案例内容 -->
  <block wx:if="{{!loading && caseDetail}}">
    <!-- Hero 全屏区域 -->
    <view class="hero-section">
      <image class="hero-bg" src="{{caseDetail.cover_image || '/images/placeholder-case.jpg'}}" mode="aspectFill"/>
      <view class="hero-gradient"></view>
      
      <view class="hero-content">
        <view class="back-float" bindtap="goBack">
          <text class="back-arrow">←</text>
        </view>
        
        <view class="hero-text">
          <view class="case-meta">
            <text wx:if="{{caseDetail.is_featured}}" class="featured-badge">精选案例</text>
            <text wx:if="{{caseDetail.location}}" class="location">
              📍 {{caseDetail.location}}
            </text>
          </view>
          
          <text class="case-title">{{caseDetail.title}}</text>
          
          <text wx:if="{{caseDetail.subtitle || caseDetail.style}}" class="case-subtitle">
            {{caseDetail.subtitle || caseDetail.style + ' · ' + caseDetail.area + '㎡'}}
          </text>
          
          <view class="case-tags">
            <text wx:if="{{caseDetail.style}}" class="tag">{{caseDetail.style}}</text>
            <text wx:if="{{caseDetail.house_type}}" class="tag">{{caseDetail.house_type}}</text>
            <text wx:if="{{caseDetail.area}}" class="tag">{{caseDetail.area}}㎡</text>
            <text wx:if="{{caseDetail.package_type}}" class="tag highlight">{{caseDetail.package_type}}</text>
          </view>
        </view>
        
        <view class="scroll-hint" bindtap="scrollToContent">
          <text>向下滑动</text>
          <text class="scroll-arrow">↓</text>
        </view>
      </view>
    </view>

    <!-- 项目概览 -->
    <view class="overview-section" id="content">
      <view class="container">
        <view class="overview-grid">
          <view class="overview-item">
            <text class="label">户型</text>
            <text class="value">{{caseDetail.house_type || '-'}}</text>
          </view>
          <view class="overview-item">
            <text class="label">面积</text>
            <text class="value">{{caseDetail.area ? caseDetail.area + '㎡' : '-'}}</text>
          </view>
          <view class="overview-item">
            <text class="label">风格</text>
            <text class="value">{{caseDetail.style || '-'}}</text>
          </view>
          <view class="overview-item">
            <text class="label">工期</text>
            <text class="value">{{caseDetail.duration || '90'}}天</text>
          </view>
          <view class="overview-item highlight" wx:if="{{caseDetail.total_price}}">
            <text class="label">全案总价</text>
            <text class="value price">¥{{formatPrice(caseDetail.total_price)}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 设计理念 -->
    <view class="concept-section" wx:if="{{caseDetail.design_concept}}">
      <view class="container">
        <text class="section-title">设计理念</text>
        <text class="concept-text">{{caseDetail.design_concept}}</text>
      </view>
    </view>

    <!-- 图片画廊 -->
    <view class="gallery-section" wx:if="{{mediaList.length > 0}}">
      <view class="container">
        <text class="section-title">案例图集</text>
        <view class="gallery-grid">
          <view
            wx:for="{{mediaList}}"
            wx:key="index"
            class="gallery-item {{index % 5 === 0 ? 'large' : ''}} {{index % 5 === 3 ? 'wide' : ''}}"
            bindtap="previewImage"
            data-index="{{index}}"
          >
            <image src="{{item.url || item.file_url}}" mode="aspectFill" lazy-load/>
            <view class="item-overlay">
              <text class="zoom-icon">🔍</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- VR 体验 -->
    <view class="vr-section" wx:if="{{caseDetail.vr_link}}">
      <view class="container">
        <text class="section-title">360° 全景体验</text>
        <view class="vr-card" bindtap="openVR">
          <image src="{{caseDetail.cover_image}}" mode="aspectFill"/>
          <view class="vr-overlay">
            <view class="vr-play-btn">▶</view>
            <text>点击体验沉浸式 VR 全景</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 设计亮点 -->
    <view class="highlights-section" wx:if="{{caseDetail.design_highlights}}">
      <view class="container">
        <text class="section-title">设计亮点</text>
        <text class="highlights-text">{{caseDetail.design_highlights}}</text>
      </view>
    </view>

    <!-- 施工时间轴 -->
    <view class="timeline-section" wx:if="{{timelineList.length > 0}}">
      <view class="container">
        <text class="section-title">施工进程</text>
        <view class="timeline">
          <view
            wx:for="{{timelineList}}"
            wx:key="id"
            class="timeline-item {{index === 0 ? 'active' : ''}}"
          >
            <view class="timeline-dot"></view>
            <view class="timeline-content">
              <text class="timeline-date">{{formatDate(item.node_time)}}</text>
              <text class="timeline-title">{{item.title}}</text>
              <text class="timeline-desc">{{item.content}}</text>
              <view wx:if="{{item.media_urls}}" class="timeline-images">
                <image
                  wx:for="{{parseMediaUrls(item.media_urls).slice(0, 3)}}"
                  wx:for-item="imgUrl"
                  wx:for-index="imgIdx"
                  wx:key="imgIdx"
                  src="{{imgUrl}}"
                  mode="aspectFill"
                  bindtap="previewTimelineImage"
                  data-url="{{imgUrl}}"
                />
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 使用产品 -->
    <view class="products-section" wx:if="{{relatedProducts.length > 0}}">
      <view class="container">
        <text class="section-title">使用产品</text>
        <scroll-view class="products-scroll" scroll-x>
          <view
            wx:for="{{relatedProducts}}"
            wx:key="id"
            class="product-card"
            bindtap="goToProduct"
            data-id="{{item.id}}"
          >
            <image src="{{item.main_image || '/images/placeholder.png'}}" mode="aspectFill"/>
            <view class="product-info">
              <text class="product-name">{{item.name}}</text>
              <text class="product-brand">{{item.brand}}</text>
              <text class="product-price">¥{{item.sale_price}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 底部 CTA -->
    <view class="cta-section">
      <view class="container">
        <text class="cta-title">喜欢这套设计？</text>
        <text class="cta-subtitle">预约设计师，获取专属方案</text>
        <view class="cta-buttons">
          <button class="btn-primary" bindtap="showLeadForm">免费咨询</button>
          <button class="btn-secondary" bindtap="handleSubscribe">
            {{isSubscribed ? '已订阅' : '订阅更新'}}
          </button>
        </view>
      </view>
    </view>

    <!-- 底部信息 -->
    <view class="case-footer">
      <view class="container">
        <view class="footer-stats">
          <text>👁 {{caseDetail.view_count || 0}} 浏览</text>
          <text>★ {{caseDetail.like_count || 0}} 收藏</text>
          <text>🔔 {{caseDetail.subscription_count || 0}} 订阅</text>
        </view>
        <text class="copyright">© 梵木里全案服务</text>
      </view>
    </view>
  </block>

  <!-- 留资表单弹窗 -->
  <view class="lead-modal {{showLeadModal ? 'show' : ''}}" bindtap="hideLeadForm">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">获取专属方案</text>
        <text class="modal-close" bindtap="hideLeadForm">×</text>
      </view>
      <view class="modal-body">
        <input type="text" placeholder="您的姓名" value="{{leadForm.name}}" bindinput="onNameInput"/>
        <input type="number" placeholder="手机号码" value="{{leadForm.phone}}" bindinput="onPhoneInput"/>
        <textarea placeholder="留言（选填）" value="{{leadForm.remark}}" bindinput="onRemarkInput"/>
        <button class="btn-primary" bindtap="submitLead">立即预约</button>
      </view>
    </view>
  </view>
</view>
