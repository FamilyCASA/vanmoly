/* 页面基础 */
.case-detail-page {
  min-height: 100vh;
  background: #0a0a0a;
  color: #fff;
}

/* 固定导航栏 */
.fixed-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(10, 10, 10, 0.95);
  backdrop-filter: blur(20px);
  transform: translateY(-100%);
  transition: transform 0.3s ease;
}

.fixed-nav.visible {
  transform: translateY(0);
}

.nav-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  height: 44px;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.back-icon {
  font-size: 20px;
  color: #fff;
}

.nav-title {
  font-size: 16px;
  font-weight: 500;
  color: #fff;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  display: flex;
  gap: 16px;
}

.nav-icon {
  font-size: 20px;
  color: #fff;
  opacity: 0.8;
}

.nav-icon.active {
  color: #ffd700;
  opacity: 1;
}

/* 加载状态 */
.loading-screen {
  min-height: 100vh;
  padding: 40px 20px;
}

.skeleton {
  background: #1a1a1a;
  border-radius: 8px;
  padding: 20px;
}

.skeleton-line {
  background: #2a2a2a;
  border-radius: 4px;
  height: 16px;
  margin-bottom: 12px;
}

/* Hero 全屏区域 */
.hero-section {
  position: relative;
  height: 100vh;
  min-height: 600px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-gradient {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to top,
    rgba(10, 10, 10, 1) 0%,
    rgba(10, 10, 10, 0.7) 40%,
    rgba(10, 10, 10, 0.3) 70%,
    rgba(10, 10, 10, 0.1) 100%
  );
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 60px 20px 40px;
}

.back-float {
  position: absolute;
  top: 40px;
  left: 20px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 20px;
  color: #fff;
}

.hero-text {
  margin-bottom: 40px;
}

.case-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.featured-badge {
  padding: 4px 12px;
  background: linear-gradient(135deg, #8B5A2B 0%, #a67c52 100%);
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
}

.location {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
}

.case-title {
  display: block;
  font-size: 32px;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 12px;
  letter-spacing: -0.02em;
}

.case-subtitle {
  display: block;
  font-size: 16px;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20px;
  font-weight: 300;
}

.case-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  padding: 6px 14px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}

.tag.highlight {
  background: rgba(139, 90, 43, 0.3);
  border-color: rgba(139, 90, 43, 0.5);
  color: #d4a574;
}

.scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  color: rgba(255, 255, 255, 0.6);
  font-size: 12px;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-8px); }
  60% { transform: translateY(-4px); }
}

.scroll-arrow {
  font-size: 16px;
}

/* 通用容器 */
.container {
  padding: 0 20px;
}

/* 项目概览 */
.overview-section {
  padding: 40px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.overview-grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}

.overview-item {
  text-align: center;
  flex: 1;
  min-width: 80px;
}

.overview-item .label {
  display: block;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 6px;
  text-transform: uppercase;
}

.overview-item .value {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #fff;
}

.overview-item .value.price {
  color: #d4a574;
  font-size: 20px;
}



.section-title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 24px;
  text-align: center;
}

.concept-text {
  display: block;
  font-size: 15px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

/* 图片画廊 */
.gallery-section {
  padding: 50px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

.gallery-item {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 1;
}

.gallery-item.large {
  grid-column: span 2;
  grid-row: span 2;
}

.gallery-item image {
  width: 100%;
  height: 100%;
}

.item-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.gallery-item:active .item-overlay {
  opacity: 1;
}

.zoom-icon {
  font-size: 24px;
  color: #fff;
}

/* VR 区域 */
.vr-section {
  padding: 50px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.vr-card {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 21/9;
}

.vr-card image {
  width: 100%;
  height: 100%;
}

.vr-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.vr-play-btn {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: #8B5A2B;
}

.vr-overlay text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.9);
}



.highlights-text {
  display: block;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.8);
}

/* 时间轴 */
.timeline-section {
  padding: 50px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.timeline {
  padding-left: 20px;
}

.timeline-item {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  position: relative;
}

.timeline-item:not(:last-child)::before {
  content: '';
  position: absolute;
  left: 5px;
  top: 32px;
  bottom: 0;
  width: 2px;
  background: rgba(255, 255, 255, 0.1);
}

.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
  margin-top: 4px;
}

.timeline-item.active .timeline-dot {
  background: #8B5A2B;
  box-shadow: 0 0 0 4px rgba(139, 90, 43, 0.3);
}

.timeline-content {
  flex: 1;
}

.timeline-date {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
}

.timeline-title {
  display: block;
  font-size: 15px;
  font-weight: 600;
  margin: 4px 0;
}

.timeline-desc {
  display: block;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

.timeline-images {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.timeline-images image {
  width: 70px;
  height: 70px;
  border-radius: 6px;
}

/* 相关产品 */
.products-section {
  padding: 50px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.products-scroll {
  white-space: nowrap;
}

.product-card {
  display: inline-block;
  width: 160px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10px;
  overflow: hidden;
  margin-right: 12px;
}

.product-card image {
  width: 160px;
  height: 160px;
}

.product-info {
  padding: 12px;
}

.product-name {
  display: block;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-brand {
  display: block;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 6px;
}

.product-price {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #d4a574;
}

/* CTA 区域 */
.cta-section {
  padding: 60px 0;
  text-align: center;
  background: linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 100%);
}

.cta-title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 8px;
}

.cta-subtitle {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 28px;
}

.cta-buttons {
  display: flex;
  justify-content: center;
  gap: 12px;
}

.btn-primary {
  padding: 14px 32px;
  background: #8B5A2B;
  border: none;
  border-radius: 24px;
  color: #fff;
  font-size: 15px;
  font-weight: 500;
}

.btn-secondary {
  padding: 14px 32px;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 24px;
  color: #fff;
  font-size: 15px;
}

/* 底部 */
.case-footer {
  padding: 30px 0;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  text-align: center;
}

.footer-stats {
  display: flex;
  justify-content: center;
  gap: 24px;
  margin-bottom: 16px;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
}

.copyright {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.3);
}

/* 留资弹窗 */
.lead-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.lead-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 100%;
  background: #1a1a1a;
  border-radius: 20px 20px 0 0;
  padding: 24px 20px 40px;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.lead-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
}

.modal-close {
  font-size: 24px;
  color: rgba(255, 255, 255, 0.5);
  padding: 0 4px;
}

.modal-body input,
.modal-body textarea {
  width: 100%;
  padding: 14px 16px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  color: #fff;
  font-size: 15px;
  margin-bottom: 12px;
  box-sizing: border-box;
}

.modal-body textarea {
  height: 100px;
  resize: none;
}

.modal-body .btn-primary {
  width: 100%;
  margin-top: 8px;
}
