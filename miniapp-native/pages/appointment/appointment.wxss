/* 预约量尺 - 深化设计版 */

page { background: #0a0a1a; }
.appointment-page { min-height: 100vh; background: #0a0a1a; color: #E8E8E8; font-family: -apple-system, 'PingFang SC', sans-serif; }

/* ===== HERO ===== */
.hero-section { position: relative; min-height: 85vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; }
.hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
.hero-content { position: relative; z-index: 2; text-align: center; color: #fff; display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 0 40rpx; padding-top: 60rpx; }
.hero-eyebrow { font-size: 24rpx; letter-spacing: 6rpx; color: rgba(255,255,255,0.7); text-transform: uppercase; }
.hero-title { font-size: 80rpx; font-weight: 300; letter-spacing: 12rpx; }
.hero-subtitle { font-size: 32rpx; font-weight: 300; opacity: 0.85; letter-spacing: 2rpx; }

/* 服务类型快捷入口 */
.service-types-hero { display: flex; gap: 24rpx; margin: 32rpx 0; flex-wrap: wrap; justify-content: center; }
.sth-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 24rpx 32rpx; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.15); border-radius: 16rpx; transition: all 0.3s; }
.sth-item.active { background: rgba(212,175,55,0.2); border-color: #D4AF37; }
.sth-icon { font-size: 48rpx; }
.sth-name { font-size: 24rpx; color: #fff; letter-spacing: 2rpx; }

.hero-scroll-btn { display: flex; align-items: center; gap: 16rpx; border: 1rpx solid rgba(255,255,255,0.5); padding: 20rpx 48rpx; font-size: 26rpx; letter-spacing: 4rpx; margin-top: 32rpx; }
.scroll-arrow { font-size: 28rpx; }

/* 客服快捷入口 */
.hero-contact { position: absolute; bottom: 60rpx; left: 0; right: 0; display: flex; justify-content: center; gap: 40rpx; z-index: 3; }
.hc-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 32rpx; background: rgba(255,255,255,0.1); border-radius: 40rpx; }
.hci-icon { font-size: 32rpx; }
.hci-text { font-size: 24rpx; color: #fff; }

/* ===== 服务特色 ===== */
.features-section { padding: 80rpx 40rpx; background: #12121f; }
.section-header { text-align: center; margin-bottom: 48rpx; }
.section-title { font-size: 48rpx; font-weight: 300; color: #fff; letter-spacing: 6rpx; display: block; }
.section-sub { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-top: 12rpx; display: block; }
.features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24rpx; }
.feature-card { text-align: center; padding: 40rpx 24rpx; border-radius: 16rpx; background: rgba(255,255,255,0.03); border: 1rpx solid rgba(255,255,255,0.06); }
.feature-icon-wrap { width: 96rpx; height: 96rpx; background: rgba(212,175,55,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20rpx; }
.feature-icon { font-size: 48rpx; }
.feature-title { display: block; font-size: 30rpx; font-weight: 500; color: #fff; margin-bottom: 12rpx; }
.feature-desc { display: block; font-size: 24rpx; color: #A0A0B8; line-height: 1.7; }

/* ===== 设计师团队 ===== */
.designers-section { padding: 60rpx 0; background: #0a0a1a; }
.designers-scroll { white-space: nowrap; padding: 0 40rpx; }
.designer-card { display: inline-block; width: 280rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; padding: 32rpx 24rpx; margin-right: 20rpx; text-align: center; position: relative; border: 2rpx solid transparent; transition: all 0.3s; vertical-align: top; }
.designer-card.selected { border-color: #D4AF37; background: rgba(212,175,55,0.1); }
.dc-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-bottom: 16rpx; background: rgba(255,255,255,0.1); }
.dc-name { font-size: 30rpx; color: #fff; display: block; font-weight: 500; }
.dc-title { font-size: 22rpx; color: rgba(255,255,255,0.5); margin-top: 8rpx; display: block; }
.dc-tags { margin-top: 16rpx; }
.dc-tag { display: inline-block; font-size: 20rpx; color: #D4AF37; background: rgba(212,175,55,0.15); padding: 4rpx 12rpx; border-radius: 8rpx; margin: 4rpx; }
.dc-stats { margin-top: 16rpx; display: flex; justify-content: center; gap: 24rpx; }
.dcs-item { font-size: 20rpx; color: rgba(255,255,255,0.5); }
.dc-check { position: absolute; top: 16rpx; right: 16rpx; width: 40rpx; height: 40rpx; background: #D4AF37; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0a0a1a; font-size: 24rpx; font-weight: bold; }

/* ===== 表单区 ===== */
.form-section { padding: 60rpx 40rpx; background: #0a0a1a; }
.form-wrapper { background: rgba(255,255,255,0.03); padding: 48rpx 40rpx; border-radius: 20rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.form-header { text-align: center; margin-bottom: 40rpx; }
.fh-title { display: block; font-size: 40rpx; font-weight: 400; color: #fff; margin-bottom: 12rpx; }
.fh-sub { font-size: 26rpx; color: #A0A0B8; }

/* 步骤指示器 */
.step-indicator { display: flex; align-items: center; justify-content: center; margin-bottom: 48rpx; flex-wrap: wrap; }
.step-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.step-circle { width: 56rpx; height: 56rpx; border-radius: 50%; border: 2rpx solid #444; display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #606080; }
.step-item.active .step-circle { border-color: #D4AF37; background: #D4AF37; color: #0a0a1a; }
.step-item.completed .step-circle { border-color: #52c41a; background: #52c41a; color: #fff; }
.step-label { font-size: 22rpx; color: #606080; }
.step-item.active .step-label { color: #D4AF37; }
.step-item.completed .step-label { color: #52c41a; }
.step-line { width: 60rpx; height: 2rpx; background: #333; margin: 0 12rpx; margin-bottom: 28rpx; }
.step-line.done { background: #52c41a; }

/* 表单步骤 */
.form-step { display: flex; flex-direction: column; gap: 32rpx; }
.form-row { display: flex; gap: 24rpx; }
.form-field { flex: 1; display: flex; flex-direction: column; gap: 12rpx; }
.field-label { font-size: 26rpx; color: #A0A0B8; font-weight: 400; }
.required { color: #D4AF37; }
.field-hint { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 8rpx; }

/* 服务类型选择 */
.service-type-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.st-option { padding: 24rpx; background: rgba(255,255,255,0.04); border: 2rpx solid rgba(255,255,255,0.1); border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; transition: all 0.2s; }
.st-option.active { border-color: #D4AF37; background: rgba(212,175,55,0.1); }
.sto-icon { font-size: 48rpx; }
.sto-name { font-size: 28rpx; color: #fff; font-weight: 500; }
.sto-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); }

/* 输入框 */
.field-input { background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #E8E8E8; }
.flex-1 { flex: 1; }

/* 地址输入带定位 */
.address-input-wrap { display: flex; gap: 16rpx; }
.location-btn { width: 80rpx; height: 80rpx; background: rgba(212,175,55,0.15); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.lb-icon { font-size: 36rpx; }

/* 房屋现状选项 */
.status-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.so-item { padding: 16rpx 24rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 8rpx; font-size: 26rpx; color: #fff; }
.so-item.active { background: rgba(212,175,55,0.15); border-color: #D4AF37; color: #D4AF37; }

/* 风格选择 */
.style-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.style-option { position: relative; height: 160rpx; border-radius: 12rpx; overflow: hidden; border: 2rpx solid transparent; }
.style-option.active { border-color: #D4AF37; }
.so-img { width: 100%; height: 100%; }
.so-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; justify-content: center; padding-bottom: 16rpx; }
.so-name { font-size: 24rpx; color: #fff; }
.so-check { position: absolute; top: 12rpx; right: 12rpx; width: 36rpx; height: 36rpx; background: #D4AF37; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #0a0a1a; font-size: 20rpx; }

/* 参考图片 */
.ref-images { display: flex; flex-wrap: wrap; gap: 16rpx; }
.ref-img-item { width: 160rpx; height: 160rpx; position: relative; }
.ri-img { width: 100%; height: 100%; border-radius: 8rpx; }
.ri-remove { position: absolute; top: -8rpx; right: -8rpx; width: 36rpx; height: 36rpx; background: #f5222d; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx; }
.ref-img-add { width: 160rpx; height: 160rpx; background: rgba(255,255,255,0.06); border: 1rpx dashed rgba(255,255,255,0.2); border-radius: 8rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ria-icon { font-size: 48rpx; color: rgba(255,255,255,0.3); }
.ria-text { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 8rpx; }

/* 文本域 */
.field-textarea { background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #E8E8E8; min-height: 160rpx; width: 100%; box-sizing: border-box; }

/* picker */
.picker-trigger { display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 12rpx; padding: 20rpx 24rpx; }
.pv-text { font-size: 28rpx; color: #E8E8E8; }
.pv-placeholder { font-size: 28rpx; color: #606080; }
.pv-arrow { font-size: 28rpx; color: #606080; }

/* 已选设计师 */
.selected-designer { display: flex; align-items: center; gap: 16rpx; padding: 20rpx; background: rgba(212,175,55,0.1); border-radius: 12rpx; }
.sd-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; }
.sd-info { flex: 1; }
.sd-name { font-size: 28rpx; color: #fff; display: block; }
.sd-title { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.sd-remove { font-size: 24rpx; color: #D4AF37; }
.no-designer { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; background: rgba(255,255,255,0.04); border-radius: 12rpx; border: 1rpx dashed rgba(255,255,255,0.2); }
.nd-icon { font-size: 40rpx; }
.nd-text { font-size: 26rpx; color: rgba(255,255,255,0.6); }

/* 日历 */
.calendar-wrap { background: rgba(255,255,255,0.04); border-radius: 16rpx; padding: 24rpx; }
.cw-header { display: flex; align-items: center; justify-content: center; gap: 32rpx; margin-bottom: 24rpx; }
.cw-nav { width: 48rpx; height: 48rpx; background: rgba(255,255,255,0.1); border-radius: 8rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #fff; }
.cw-title { font-size: 30rpx; color: #fff; font-weight: 500; }
.cw-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8rpx; margin-bottom: 16rpx; }
.cw-weekdays text { text-align: center; font-size: 24rpx; color: rgba(255,255,255,0.5); }
.cw-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8rpx; }
.cwd-item { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #fff; border-radius: 8rpx; background: transparent; }
.cwd-item.today { background: rgba(255,255,255,0.1); }
.cwd-item.selected { background: #D4AF37; color: #0a0a1a; font-weight: 600; }
.cwd-item.disabled { color: #404040; }

/* 时间段 */
.time-slots { }
.ts-group { margin-bottom: 24rpx; }
.tsg-label { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-bottom: 12rpx; display: block; }
.tsg-slots { display: flex; gap: 16rpx; }
.ts-slot { flex: 1; padding: 20rpx; text-align: center; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 8rpx; font-size: 28rpx; color: #fff; }
.ts-slot.active { background: rgba(212,175,55,0.2); border-color: #D4AF37; color: #D4AF37; }
.ts-slot.disabled { opacity: 0.3; }

/* 按钮组 */
.form-actions { display: flex; justify-content: center; gap: 24rpx; margin-top: 48rpx; }
.btn-prev, .btn-next, .btn-submit { display: inline-flex; align-items: center; justify-content: center; min-width: 200rpx; padding: 24rpx 48rpx; border-radius: 12rpx; font-size: 28rpx; letter-spacing: 2rpx; }
.btn-prev { background: transparent; border: 2rpx solid rgba(255,255,255,0.2); color: #A0A0B8; }
.btn-next { background: transparent; border: 2rpx solid #D4AF37; color: #D4AF37; }
.btn-submit { background: #D4AF37; border: none; color: #0a0a1a; font-weight: 600; }
.hidden { display: none; }

/* ===== 服务流程 ===== */
.process-section { padding: 80rpx 40rpx; background: #12121f; }
.process-timeline { display: flex; justify-content: space-between; position: relative; flex-wrap: wrap; gap: 32rpx; }
.process-timeline::before { content: ''; position: absolute; top: 40rpx; left: 80rpx; right: 80rpx; height: 1rpx; background: rgba(255,255,255,0.1); }
.timeline-item { text-align: center; flex: 1; min-width: 140rpx; position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.timeline-icon { width: 80rpx; height: 80rpx; background: #0a0a1a; border: 2rpx solid #D4AF37; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.t-num { font-size: 28rpx; font-weight: 600; color: #D4AF37; }
.t-title { font-size: 28rpx; font-weight: 500; color: #fff; }
.t-desc { font-size: 22rpx; color: #A0A0B8; max-width: 160rpx; line-height: 1.5; }

/* ===== 固定悬浮按钮 ===== */
.sticky-book-btn { position: fixed; right: 32rpx; bottom: 120rpx; z-index: 900; display: flex; align-items: center; gap: 12rpx; background: linear-gradient(135deg, #D4AF37 0%, #B8962E 100%); color: #fff; border-radius: 50rpx; padding: 20rpx 36rpx; font-size: 26rpx; letter-spacing: 2rpx; box-shadow: 0 8rpx 32rpx rgba(212,175,55,0.4); opacity: 0; transform: translateX(40rpx); transition: all 0.5s; pointer-events: none; }
.sticky-book-btn.visible { opacity: 1; transform: translateX(0); pointer-events: auto; }
.sticky-icon { font-size: 32rpx; }

/* ===== 成功弹窗 ===== */
.success-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 9999; display: flex; align-items: center; justify-content: center; }
.success-box { width: 90%; max-width: 640rpx; background: #1a1a2e; border-radius: 24rpx; padding: 48rpx 40rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.success-icon { width: 96rpx; height: 96rpx; background: #52c41a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #fff; margin-bottom: 8rpx; }
.success-title { font-size: 36rpx; font-weight: 600; color: #fff; }
.success-desc { font-size: 26rpx; color: #A0A0B8; text-align: center; }
.appointment-info { background: #0a0a1a; padding: 24rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; border-radius: 12rpx; width: 100%; margin: 16rpx 0; }
.ai-label { font-size: 22rpx; color: #606080; }
.ai-id { font-size: 32rpx; color: #D4AF37; font-weight: 600; letter-spacing: 4rpx; }
.success-tips { width: 100%; display: flex; flex-direction: column; gap: 8rpx; }
.st-item { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.success-actions { display: flex; gap: 24rpx; width: 100%; margin-top: 16rpx; }
.sa-btn { flex: 1; padding: 24rpx; border-radius: 12rpx; text-align: center; }
.sa-btn.secondary { background: rgba(255,255,255,0.1); }
.sa-btn.secondary text { color: #fff; font-size: 28rpx; }
.sa-btn.primary { background: #D4AF37; }
.sa-btn.primary text { color: #0a0a1a; font-size: 28rpx; font-weight: 600; }
