<!-- 预约量尺页面 -->
<view class="container">
  
  <!-- 头部 -->
  <view class="appointment-header">
    <text class="header-title">预约免费量尺</text>
    <text class="header-desc">专业设计师上门，精准测量 + 方案建议</text>
  </view>

  <!-- 服务流程 -->
  <view class="process-section card">
    <view class="process-item">
      <view class="process-num">1</view>
      <text class="process-title">在线预约</text>
      <text class="process-desc">填写基本信息</text>
    </view>
    <view class="process-arrow">→</view>
    <view class="process-item">
      <view class="process-num">2</view>
      <text class="process-title">确认时间</text>
      <text class="process-desc">顾问电话确认</text>
    </view>
    <view class="process-arrow">→</view>
    <view class="process-item">
      <view class="process-num">3</view>
      <text class="process-title">上门量尺</text>
      <text class="process-desc">设计师上门</text>
    </view>
    <view class="process-arrow">→</view>
    <view class="process-item">
      <view class="process-num">4</view>
      <text class="process-title">获取方案</text>
      <text class="process-desc">3D效果图</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-card card">
    <view class="form-item">
      <text class="form-label">您的称呼 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：张先生" value="{{form.name}}" bindinput="onInput" data-field="name"/>
    </view>

    <view class="form-item">
      <text class="form-label">手机号码 <text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" maxlength="11"/>
    </view>

    <view class="form-item">
      <text class="form-label">房屋地址 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：XX小区X栋X单元" value="{{form.address}}" bindinput="onInput" data-field="address"/>
    </view>

    <view class="form-item">
      <text class="form-label">期望量尺日期</text>
      <picker mode="date" start="{{today}}" bindchange="onDateChange">
        <view class="picker-value">
          {{form.date || '请选择日期'}}
          <text class="picker-arrow">→</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">期望时间段</text>
      <view class="time-selector">
        <view class="time-option {{form.time === item ? 'active' : ''}}" wx:for="{{timeOptions}}" wx:key="*this" bindtap="onTimeSelect" data-time="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="如有特殊要求请说明" value="{{form.remark}}" bindinput="onInput" data-field="remark" maxlength="200"/>
    </view>
  </view>

  <!-- 提交 -->
  <button class="btn btn-primary submit-btn" bindtap="submitForm">
    <text wx:if="{{!submitting}}">立即预约</text>
    <text wx:else>提交中...</text>
  </button>

  <!-- 提示 -->
  <view class="tips">
    <text class="tip-item">✓ 量尺服务完全免费，不收取任何费用</text>
    <text class="tip-item">✓ 设计师携带专业工具，测量精准</text>
    <text class="tip-item">✓ 量尺后3个工作日内提供初步方案</text>
  </view>
</view>

<!-- 成功弹窗 -->
<view class="success-popup" wx:if="{{showSuccess}}">
  <view class="success-content">
    <view class="success-icon">✓</view>
    <text class="success-title">预约成功！</text>
    <text class="success-desc">顾问将在2小时内与您确认上门时间</text>
    <button class="btn btn-primary" bindtap="closeSuccess">知道了</button>
  </view>
</view>