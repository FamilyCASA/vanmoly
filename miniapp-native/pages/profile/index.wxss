/* 我的页面 - 完整版 - 暗黑深空风格 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
  padding: 100rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}
.user-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(circle at 30% 20%, rgba(212,175,55,0.08) 0%, transparent 50%);
  pointer-events: none;
}
.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.avatar-img {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 3px solid rgba(212,175,55,0.4);
}
.avatar-placeholder {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4AF37, #B8962E);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #0a0a1a;
  font-weight: 700;
  border: 3px solid rgba(212,175,55,0.3);
}
.avatar-vip {
  position: absolute;
  bottom: -4rpx; right: -4rpx;
  background: linear-gradient(135deg, #D4AF37, #FFD700);
  color: #0a0a1a;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  border: 2rpx solid #0a0a1a;
}
.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.user-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.role {
  font-size: 22rpx;
  color: #D4AF37;
  background: rgba(212,175,55,0.12);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.role.visitor {
  color: #A0A0B8;
  background: rgba(255,255,255,0.06);
}
.level {
  font-size: 20rpx;
  color: #6495ED;
  background: rgba(100,149,237,0.12);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}
.user-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}
.us-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  padding: 8rpx 16rpx;
}
.us-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #D4AF37;
}
.us-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
}
.us-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.1);
}
.login-btn {
  background: #D4AF37;
  color: #0a0a1a;
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 40rpx;
  border-radius: 32rpx;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
}
.settings-btn {
  width: 64rpx; height: 64rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.settings-btn text {
  font-size: 32rpx;
  color: rgba(255,255,255,0.7);
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  background: #1a1a2e;
  margin: -24rpx 24rpx 0;
  border-radius: 20rpx;
  position: relative;
  z-index: 2;
  border: 1px solid rgba(255,255,255,0.06);
}
.qa-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}
.qa-icon {
  font-size: 40rpx;
  width: 64rpx; height: 64rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qa-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.qa-badge {
  position: absolute;
  top: -8rpx; right: 8rpx;
  min-width: 32rpx; height: 32rpx;
  background: #D4AF37;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
.qa-badge text {
  font-size: 18rpx;
  font-weight: 700;
  color: #0a0a1a;
}
.qa-dot {
  position: absolute;
  top: -4rpx; right: 12rpx;
  width: 16rpx; height: 16rpx;
  background: #FF6B6B;
  border-radius: 50%;
  border: 2rpx solid #1a1a2e;
}

/* 菜单组 */
.menu-group {
  background: #1a1a2e;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
}
.menu-title-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx 12rpx;
}
.mt-text {
  font-size: 24rpx;
  color: #606080;
  letter-spacing: 2rpx;
}
.mt-badge {
  font-size: 18rpx;
  color: #D4AF37;
  background: rgba(212,175,55,0.12);
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(255,255,255,0.03); }

.mi-icon {
  font-size: 36rpx;
  width: 52rpx;
  text-align: center;
  margin-right: 20rpx;
}
.mi-name {
  flex: 1;
  font-size: 28rpx;
  color: #E8E8E8;
  letter-spacing: 1rpx;
}
.mi-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  margin-right: 12rpx;
}
.mi-desc.highlight {
  color: #D4AF37;
  font-weight: 600;
}
.mi-arrow {
  font-size: 32rpx;
  color: #606080;
  font-weight: 300;
}
.mi-badge {
  margin-right: 12rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #D4AF37;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}
.mi-badge text {
  font-size: 20rpx;
  font-weight: 700;
  color: #0a0a1a;
}
.mi-dot {
  width: 16rpx; height: 16rpx;
  background: #FF6B6B;
  border-radius: 50%;
  margin-right: 12rpx;
}
.mi-name.mi-danger { color: #FF6B6B; }
.logout-item {
  justify-content: center;
}
.logout-item .mi-name {
  flex: none;
  text-align: center;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 32rpx 16rpx;
}
.version-info text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.15);
}

/* 版权 */
.copyright {
  text-align: center;
  padding: 16rpx 32rpx 40rpx;
}
.copyright text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.15);
}