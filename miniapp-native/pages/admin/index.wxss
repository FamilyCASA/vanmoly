/* 管理后台 - 暗黑深空风格 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #12121f 100%);
  padding: 0 0 40rpx;
}

/* ===== 头部 ===== */
.page-header {
  padding: 48rpx 40rpx 32rpx;
  background: linear-gradient(135deg, rgba(212,175,55,0.08) 0%, transparent 60%);
}

.header-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.header-badge {
  padding: 6rpx 16rpx;
  background: rgba(212,175,55,0.2);
  border: 1rpx solid rgba(212,175,55,0.4);
  border-radius: 8rpx;
}

.header-badge text {
  font-size: 20rpx;
  color: #D4AF37;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 8rpx;
}

/* ===== 统计概览 ===== */
.stats-row {
  display: flex;
  padding: 0 40rpx;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.si-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.si-num.gold {
  color: #D4AF37;
}

.si-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 8rpx;
}

/* ===== 分区 ===== */
.section {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.sec-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  display: block;
}

/* ===== 菜单网格 ===== */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.menu-item {
  width: calc((100% - 32rpx) / 3);
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.2s;
}

.menu-item:active {
  background: rgba(255,255,255,0.08);
  border-color: rgba(212,175,55,0.3);
}

.menu-item.primary {
  background: rgba(212,175,55,0.1);
  border-color: rgba(212,175,55,0.25);
}

.mi-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.mi-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #fff;
  text-align: center;
}

.mi-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  margin-top: 6rpx;
  text-align: center;
}

.mi-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: #f5222d;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mi-badge text {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

/* ===== 底部 ===== */
.footer-tip {
  text-align: center;
  padding: 40rpx;
}

.footer-tip text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}
