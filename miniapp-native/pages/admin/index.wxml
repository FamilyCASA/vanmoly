<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">管理后台</text>
    <text class="version">v3.0.4</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-num">{{stats.customers}}</text>
      <text class="stat-label">客户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.quotes}}</text>
      <text class="stat-label">报价单</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.orders}}</text>
      <text class="stat-label">进行中</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">¥{{stats.revenue}}</text>
      <text class="stat-label">本月营收</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-section">
    <view class="section-title">快捷入口</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goToWeb" data-path="/customers">
        <view class="quick-icon" style="background: #1890ff;">👥</view>
        <text>客户管理</text>
      </view>
      <view class="quick-item" bindtap="goToWeb" data-path="/quotes">
        <view class="quick-icon" style="background: #52c41a;">📋</view>
        <text>报价管理</text>
      </view>
      <view class="quick-item" bindtap="goToWeb" data-path="/materials">
        <view class="quick-icon" style="background: #722ed1;">📦</view>
        <text>物料管理</text>
      </view>
      <view class="quick-item" bindtap="goToWeb" data-path="/workflow">
        <view class="quick-icon" style="background: #eb2f96;">📊</view>
        <text>工作流程</text>
      </view>
      <view class="quick-item" bindtap="goToWeb" data-path="/employees">
        <view class="quick-icon" style="background: #fa8c16;">🧑‍💼</view>
        <text>员工管理</text>
      </view>
      <view class="quick-item" bindtap="goToWeb" data-path="/finance">
        <view class="quick-icon" style="background: #13c2c2;">💰</view>
        <text>财务看板</text>
      </view>
    </view>
  </view>

  <!-- 系统状态 -->
  <view class="status-section">
    <view class="section-title">系统状态</view>
    <view class="status-list">
      <view class="status-item">
        <text class="status-label">后端服务</text>
        <text class="status-value {{backendStatus === '正常' ? 'success' : 'error'}}">{{backendStatus}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">数据库</text>
        <text class="status-value {{dbStatus === '正常' ? 'success' : 'error'}}">{{dbStatus}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">版本号</text>
        <text class="status-value">v3.0.4</text>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <text class="tip-text">提示：完整的管理功能请在 Web 端使用，体验更佳</text>
    <button class="web-btn" bindtap="openWebAdmin">打开 Web 管理后台</button>
  </view>
</view>