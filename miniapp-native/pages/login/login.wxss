/* 微信登录页 - 暗黑深空 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #1a1a2e 100%);
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
}

/* 品牌头部 */
.login-header {
  padding: 120rpx 0 80rpx;
  text-align: center;
}

.login-brand {
  display: block;
  font-size: 24rpx;
  color: #D4AF37;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
}

.login-title {
  display: block;
  font-size: 44rpx;
  font-weight: 300;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #A0A0B8;
}

/* 登录内容 */
.login-content {
  flex: 1;
}

.login-section {
  margin-bottom: 48rpx;
}

.login-section-title text {
  font-size: 30rpx;
  font-weight: 600;
  color: #e8e8e8;
  margin-bottom: 32rpx;
}

/* 表单 */
.login-form {
  margin-bottom: 32rpx;
}

.input-group {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.10);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  transition: border-color 0.2s;
}

.input-group:focus-within {
  border-color: rgba(212,175,55,0.4);
}

.input-prefix {
  font-size: 30rpx;
  color: #e8e8e8;
  margin-right: 20rpx;
  padding-right: 20rpx;
  border-right: 1rpx solid rgba(255,255,255,0.10);
}

.login-input {
  flex: 1;
  font-size: 30rpx;
  color: #e8e8e8;
  height: 44rpx;
}

.sms-btn {
  font-size: 26rpx;
  color: #D4AF37;
  padding: 8rpx 20rpx;
  white-space: nowrap;
}

.sms-btn.disabled {
  color: #606080;
}

/* 登录按钮 */
.btn-login {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #D4AF37 0%, #c9a52f 100%);
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #0a0a1a;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.btn-login.disabled {
  opacity: 0.4;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255,255,255,0.08);
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #606080;
}

/* 微信登录 */
.wechat-section {
  text-align: center;
}

.btn-wechat {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 24rpx 0;
  background: #07C160;
  border: none;
  border-radius: 48rpx;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.wechat-icon {
  font-size: 36rpx;
}

/* 用户协议 */
.agreement {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 32rpx 0 48rpx;
  justify-content: center;
}

.agreement-check {
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  border: 2rpx solid rgba(255,255,255,0.20);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #0a0a1a;
  margin-top: 2rpx;
}

.agreement-check.checked {
  background: #D4AF37;
  border-color: #D4AF37;
}

.agreement-text {
  font-size: 22rpx;
  color: #606080;
  line-height: 1.6;
}

.link {
  color: #D4AF37;
}
