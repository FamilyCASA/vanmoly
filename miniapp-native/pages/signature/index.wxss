/* 电子签名 - 暗黑深空风格 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
}

.page-header {
  text-align: center;
  padding: 24rpx 0 32rpx;
}

.ph-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.ph-desc {
  font-size: 26rpx;
  color: #A0A0B8;
  display: block;
}

.canvas-wrap {
  position: relative;
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.sig-canvas {
  width: 100%;
  height: 500rpx;
  background: #1a1a2e;
}

.canvas-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.canvas-hint text {
  font-size: 30rpx;
  color: #606080;
}

.sig-line {
  position: absolute;
  bottom: 80rpx;
  left: 48rpx;
  right: 48rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.20);
}

.sig-label-text {
  position: absolute;
  bottom: 56rpx;
  right: 48rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.30);
}

.actions-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.act-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.act-btn.clear {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.12);
  color: #A0A0B8;
}

.act-btn.save {
  background: #D4AF37;
  color: #0a0a1a;
}

.preview-section {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx;
}

.ps-title {
  font-size: 26rpx;
  color: #A0A0B8;
  display: block;
  margin-bottom: 16rpx;
}

.ps-image {
  width: 100%;
  height: 200rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
}