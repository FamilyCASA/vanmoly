<!-- 电子签名 - 暗黑深空风格 -->
<view class="page">

  <!-- 头部 -->
  <view class="page-header">
    <text class="ph-title">手写签名</text>
    <text class="ph-desc">请在下方区域手写您的签名</text>
  </view>

  <!-- 画布 -->
  <view class="canvas-wrap">
    <canvas 
      canvas-id="signatureCanvas" 
      class="sig-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
    <view class="canvas-hint" wx:if="{{!hasDrawn}}">
      <text>✍️ 请在此处手写签名</text>
    </view>
    <!-- 签名底线 -->
    <view class="sig-line"></view>
    <view class="sig-label-text">签名</view>
  </view>

  <!-- 操作 -->
  <view class="actions-row">
    <view class="act-btn clear" bindtap="clearCanvas">
      <text>🗑 清空</text>
    </view>
    <view class="act-btn save" bindtap="saveSignature">
      <text>💾 保存签名</text>
    </view>
  </view>

  <!-- 预览 -->
  <view class="preview-section" wx:if="{{signatureImage}}">
    <text class="ps-title">签名预览</text>
    <image src="{{signatureImage}}" mode="aspectFit" class="ps-image"/>
  </view>

</view>