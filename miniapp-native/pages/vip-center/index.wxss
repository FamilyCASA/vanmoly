/* 会员中心 */
.page { background: #0a0a1a; min-height: 100vh; }
.vip-header { background: linear-gradient(135deg, #2a2a1e 0%, #3a3a2e 50%, #2a2a1e 100%); padding: 60rpx 40rpx 48rpx; display: flex; align-items: center; gap: 24rpx; position: relative; overflow: hidden; }
.vip-header::before { content: ''; position: absolute; top: -60rpx; right: -60rpx; width: 200rpx; height: 200rpx; background: radial-gradient(circle, rgba(212,175,55,0.2) 0%, transparent 70%); }
.vh-badge { background: linear-gradient(135deg, #D4AF37, #FFD700); padding: 8rpx 20rpx; border-radius: 20rpx; flex-shrink: 0; }
.vh-badge text { font-size: 22rpx; color: #0a0a1a; font-weight: 700; }
.vh-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.vhi-name { font-size: 34rpx; font-weight: 700; color: #fff; }
.vhi-expire { font-size: 22rpx; color: #D4AF37; }
.vhi-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.vh-btn { padding: 16rpx 32rpx; background: linear-gradient(135deg, #D4AF37, #FFD700); border-radius: 28rpx; flex-shrink: 0; }
.vh-btn text { font-size: 26rpx; color: #0a0a1a; font-weight: 600; }
.vh-btn.renew { background: rgba(255,255,255,0.1); }
.vh-btn.renew text { color: #D4AF37; }
.privilege-list { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; padding: 24rpx; }
.privilege-item { background: #1a1a2e; border-radius: 16rpx; padding: 24rpx 16rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; border: 1rpx solid rgba(255,255,255,0.06); position: relative; }
.pi-icon { font-size: 40rpx; }
.pi-name { font-size: 24rpx; color: #fff; font-weight: 600; }
.pi-desc { font-size: 20rpx; color: rgba(255,255,255,0.4); text-align: center; }
.pi-badge { position: absolute; top: 8rpx; right: 8rpx; background: rgba(212,175,55,0.15); border-radius: 8rpx; padding: 2rpx 8rpx; }
.pi-badge text { font-size: 16rpx; color: #D4AF37; }
.section-title { padding: 24rpx 32rpx 16rpx; }
.section-title text { font-size: 30rpx; font-weight: 600; color: #fff; }
.plan-list { display: flex; gap: 16rpx; padding: 0 24rpx 24rpx; }
.plan-card { flex: 1; background: #1a1a2e; border-radius: 16rpx; padding: 28rpx 16rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; border: 2rpx solid rgba(255,255,255,0.06); }
.plan-card.selected { border-color: #D4AF37; background: rgba(212,175,55,0.06); }
.pc-duration { font-size: 28rpx; color: #fff; font-weight: 600; }
.pc-price { font-size: 36rpx; color: #D4AF37; font-weight: 700; }
.pc-original { font-size: 22rpx; color: rgba(255,255,255,0.3); text-decoration: line-through; }