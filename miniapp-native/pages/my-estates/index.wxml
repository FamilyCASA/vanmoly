<!-- 我的楼盘/房产 -->
<view class="page">
  <!-- 头部 -->
  <view class="page-header">
    <text class="page-title">我的楼盘</text>
    <view class="add-btn" bindtap="addEstate">
      <text>+ 添加</text>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && estates.length === 0}}">
    <text class="empty-icon">🏠</text>
    <text class="empty-title">暂无房产信息</text>
    <text class="empty-desc">添加您的房产信息，获取专属服务</text>
    <view class="empty-btn" bindtap="addEstate">
      <text>立即添加</text>
    </view>
  </view>

  <!-- 房产列表 -->
  <view class="estate-list" wx:else>
    <view class="estate-card" wx:for="{{estates}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="ec-header">
        <text class="ec-name">{{item.name || item.community_name}}</text>
        <text class="ec-status {{item.is_primary ? 'primary' : ''}}">{{item.is_primary ? '默认' : ''}}</text>
      </view>
      <view class="ec-info">
        <view class="eci-item">
          <text class="eci-label">地址</text>
          <text class="eci-value">{{item.address || item.full_address || '-'}}</text>
        </view>
        <view class="eci-row">
          <view class="eci-item half">
            <text class="eci-label">户型</text>
            <text class="eci-value">{{item.house_type || '-'}}</text>
          </view>
          <view class="eci-item half">
            <text class="eci-label">面积</text>
            <text class="eci-value">{{item.area ? item.area + '㎡' : '-'}}</text>
          </view>
        </view>
        <view class="eci-row">
          <view class="eci-item half">
            <text class="eci-label">装修状态</text>
            <text class="eci-value">{{item.decorate_status || '未装修'}}</text>
          </view>
          <view class="eci-item half">
            <text class="eci-label">交付时间</text>
            <text class="eci-value">{{item.delivery_date || '-'}}</text>
          </view>
        </view>
      </view>
      <view class="ec-actions">
        <view class="eca-btn" catchtap="editEstate" data-id="{{item.id}}">
          <text>编辑</text>
        </view>
        <view class="eca-btn" catchtap="deleteEstate" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="bottom-tip" wx:if="{{estates.length > 0}}">
    <text>最多可添加5处房产</text>
  </view>
</view>