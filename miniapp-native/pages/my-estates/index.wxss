/* 我的楼盘/房产 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #1a1a2e;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.add-btn {
  padding: 12rpx 24rpx;
  background: #D4AF37;
  border-radius: 24rpx;
}
.add-btn text {
  font-size: 24rpx;
  color: #0a0a1a;
  font-weight: 600;
}

/* 加载态 */
.loading-wrap {
  padding: 32rpx;
}
.skeleton-card {
  height: 280rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  animation: skeleton 1.5s infinite;
}
@keyframes skeleton {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 0.3; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.empty-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 32rpx;
  text-align: center;
}
.empty-btn {
  padding: 20rpx 48rpx;
  background: #D4AF37;
  border-radius: 32rpx;
}
.empty-btn text {
  font-size: 28rpx;
  color: #0a0a1a;
  font-weight: 600;
}

/* 房产卡片 */
.estate-list {
  padding: 24rpx;
}
.estate-card {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.ec-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.ec-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
.ec-status {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  padding: 4rpx 12rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
}
.ec-status.primary {
  color: #D4AF37;
  background: rgba(212,175,55,0.12);
}
.ec-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.eci-row {
  display: flex;
  gap: 24rpx;
}
.eci-item {
  flex: 1;
}
.eci-item.half {
  flex: none;
  width: 45%;
}
.eci-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  margin-bottom: 4rpx;
}
.eci-value {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}
.ec-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.eca-btn {
  flex: 1;
  padding: 16rpx 0;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  text-align: center;
}
.eca-btn text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* 底部提示 */
.bottom-tip {
  text-align: center;
  padding: 24rpx;
}
.bottom-tip text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}