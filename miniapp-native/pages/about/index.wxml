<!-- 关于我们 -->
<view class="page">
  <view class="about-header">
    <text class="about-logo">D&B</text>
    <text class="about-name">帝标·设记家</text>
    <text class="about-slogan">让每个家都成为作品</text>
    <text class="about-version">Version 1.0.0</text>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goWebsite">
      <text class="mi-name">官方网站</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goWechat">
      <text class="mi-name">微信公众号</text>
      <text class="mi-desc">帝标设记家</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <text class="mi-name">客服电话</text>
      <text class="mi-desc">400-888-8888</text>
      <text class="mi-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="checkUpdate">
      <text class="mi-name">检查更新</text>
      <text class="mi-desc">{{latestVersion}}</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="userAgreement">
      <text class="mi-name">用户协议</text>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="privacyPolicy">
      <text class="mi-name">隐私政策</text>
      <text class="mi-arrow">›</text>
    </view>
  </view>

  <view class="about-footer">
    <text>© 2026 D&B 帝标·设记家</text>
    <text>All Rights Reserved</text>
  </view>
</view>