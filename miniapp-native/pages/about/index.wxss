/* 关于我们 */
.page { background: #0a0a1a; min-height: 100vh; }
.about-header { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx 60rpx; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); }
.about-logo { font-size: 64rpx; font-weight: 700; color: #D4AF37; letter-spacing: 4rpx; margin-bottom: 12rpx; }
.about-name { font-size: 36rpx; color: #fff; font-weight: 600; margin-bottom: 8rpx; }
.about-slogan { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 20rpx; }
.about-version { font-size: 22rpx; color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.06); padding: 4rpx 16rpx; border-radius: 16rpx; }
.menu-group { background: #1a1a2e; margin: 24rpx 24rpx 0; border-radius: 16rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,0.06); }
.menu-item { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.menu-item:last-child { border-bottom: none; }
.mi-name { flex: 1; font-size: 28rpx; color: #E8E8E8; }
.mi-desc { font-size: 24rpx; color: rgba(255,255,255,0.4); margin-right: 12rpx; }
.mi-arrow { font-size: 32rpx; color: #606080; }
.about-footer { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 60rpx 32rpx; }
.about-footer text { font-size: 22rpx; color: rgba(255,255,255,0.2); }