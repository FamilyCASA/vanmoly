/* 留资页面 - 暗黑深空风格 */
.page {
  background: #0a0a1a;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部激励 */
.lead-header {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
}

.lh-badge {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.lh-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.lh-desc {
  font-size: 26rpx;
  color: #A0A0B8;
  display: block;
}

/* 福利卡片 */
.benefits-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 32rpx;
}

.benefit-card {
  flex: 1;
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bc-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.bc-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
}

.bc-desc {
  font-size: 20rpx;
  color: #A0A0B8;
  display: block;
}

/* 表单 */
.form-card {
  background: #1a1a2e;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  border: 1px solid rgba(255,255,255,0.06);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #E8E8E8;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.required {
  color: #FF6B6B;
}

.form-input {
  height: 88rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #E8E8E8;
}

.ph {
  color: #606080;
}

/* 选项网格 */
.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.opt-item {
  padding: 14rpx 24rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #A0A0B8;
}

.opt-item.active {
  background: rgba(212,175,55,0.12);
  border-color: #D4AF37;
  color: #D4AF37;
}

/* picker */
.picker-value {
  height: 88rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pv-text {
  font-size: 28rpx;
  color: #E8E8E8;
}

.pv-ph {
  font-size: 28rpx;
  color: #606080;
}

.pv-arrow {
  font-size: 28rpx;
  color: #606080;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 160rpx;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #E8E8E8;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 20rpx;
  color: #606080;
  display: block;
  margin-top: 6rpx;
}

/* 提交按钮 */
.submit-wrap {
  padding: 0 24rpx 24rpx;
}

.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #D4AF37, #B8962E);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #0a0a1a;
}

.submit-btn:active { opacity: 0.85; }
.submit-btn.loading { opacity: 0.7; }

/* 信任背书 */
.trust-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 0 24rpx 32rpx;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ti-icon {
  font-size: 20rpx;
  color: #52c41a;
}

.ti-text {
  font-size: 22rpx;
  color: #A0A0B8;
}

/* 客户评价 */
.reviews-section {
  padding: 0 24rpx;
}

.rs-title {
  font-size: 26rpx;
  color: #A0A0B8;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}

.rs-num {
  color: #D4AF37;
  font-weight: 600;
}

.review-scroll {
  display: flex;
  gap: 16rpx;
}

.review-card {
  flex-shrink: 0;
  width: 480rpx;
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  padding: 24rpx;
}

.rc-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.rc-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4AF37, #B8962E);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #0a0a1a;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rc-info {
  display: flex;
  flex-direction: column;
}

.rc-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #E8E8E8;
}

.rc-date {
  font-size: 20rpx;
  color: #606080;
}

.rc-content {
  font-size: 26rpx;
  color: #A0A0B8;
  line-height: 1.6;
}

/* 底部 */
.page-footer {
  text-align: center;
  padding: 32rpx 32rpx 20rpx;
}

.f-copy {
  font-size: 22rpx;
  color: rgba(255,255,255,0.25);
}

/* 成功弹窗 */
.success-popup {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.success-content {
  background: #1a1a2e;
  border: 1px solid rgba(212,175,55,0.25);
  border-radius: 24rpx;
  padding: 56rpx 40rpx;
  width: 600rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #52c41a, #73d13d);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  margin-bottom: 28rpx;
}

.success-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #A0A0B8;
  display: block;
  margin-bottom: 20rpx;
}

.success-tips {
  background: rgba(212,175,55,0.08);
  border: 1px solid rgba(212,175,55,0.15);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  width: 100%;
}

.stip {
  font-size: 24rpx;
  color: #D4AF37;
  display: block;
  padding: 4rpx 0;
}

.success-btn {
  width: 100%;
  height: 88rpx;
  background: #D4AF37;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #0a0a1a;
  margin-bottom: 16rpx;
}

.success-link {
  padding: 8rpx;
}

.success-link text {
  font-size: 26rpx;
  color: #D4AF37;
}