<!-- 留资页面 - 暗黑深空风格 -->
<view class="page">

  <!-- 头部激励 -->
  <view class="lead-header">
    <view class="lh-badge">🎁</view>
    <text class="lh-title">{{title}}</text>
    <text class="lh-desc">专业设计师为您量身定制</text>
  </view>

  <!-- 福利卡片 -->
  <view class="benefits-row">
    <view class="benefit-card" wx:for="{{benefits}}" wx:key="icon">
      <text class="bc-icon">{{item.icon}}</text>
      <text class="bc-title">{{item.title}}</text>
      <text class="bc-desc">{{item.desc}}</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">您的称呼 <text class="required">*</text></text>
      <input class="form-input" placeholder="如：张先生" value="{{form.name}}" bindinput="onInput" data-field="name" placeholder-class="ph"/>
    </view>

    <view class="form-item">
      <text class="form-label">手机号码 <text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" maxlength="11" placeholder-class="ph"/>
    </view>

    <view class="form-item">
      <text class="form-label">房屋面积</text>
      <view class="option-grid">
        <view class="opt-item {{form.area === item ? 'active' : ''}}" wx:for="{{areaOptions}}" wx:key="*this" bindtap="onAreaSelect" data-area="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">装修预算</text>
      <view class="option-grid">
        <view class="opt-item {{form.budget === item ? 'active' : ''}}" wx:for="{{budgetOptions}}" wx:key="*this" bindtap="onBudgetSelect" data-budget="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">户型</text>
      <picker bindchange="onHouseTypeChange" value="{{houseTypeIndex}}" range="{{houseTypeOptions}}">
        <view class="picker-value">
          <text class="{{form.houseType ? 'pv-text' : 'pv-ph'}}">{{form.houseType || '请选择户型'}}</text>
          <text class="pv-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">装修需求</text>
      <textarea class="form-textarea" placeholder="请描述您的装修需求，如：风格偏好、特殊要求等（选填）" value="{{form.intention}}" bindinput="onInput" data-field="intention" maxlength="200" placeholder-class="ph"/>
      <text class="char-count">{{form.intention.length || 0}}/200</text>
    </view>
  </view>

  <!-- 提交 -->
  <view class="submit-wrap">
    <view class="submit-btn {{submitting ? 'loading' : ''}}" bindtap="submitForm">
      <text>🚀 立即获取免费方案</text>
    </view>
  </view>

  <!-- 信任背书 -->
  <view class="trust-row">
    <view class="trust-item"><text class="ti-icon">✓</text><text class="ti-text">信息严格保密</text></view>
    <view class="trust-item"><text class="ti-icon">✓</text><text class="ti-text">专业顾问1对1</text></view>
    <view class="trust-item"><text class="ti-icon">✓</text><text class="ti-text">不收任何费用</text></view>
  </view>

  <!-- 客户评价 -->
  <view class="reviews-section">
    <text class="rs-title">已有 <text class="rs-num">2,580+</text> 位业主获取方案</text>
    <scroll-view scroll-x class="review-scroll">
      <view class="review-card" wx:for="{{reviews}}" wx:key="id">
        <view class="rc-header">
          <view class="rc-avatar">{{item.name[0]}}</view>
          <view class="rc-info">
            <text class="rc-name">{{item.name}}</text>
            <text class="rc-date">{{item.date}}</text>
          </view>
        </view>
        <text class="rc-content">{{item.content}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="page-footer">
    <text class="f-copy">© 2026 D&B 帝标·设记家</text>
  </view>

</view>

<!-- 成功弹窗 -->
<view class="success-popup" wx:if="{{showSuccess}}" bindtap="closeSuccess">
  <view class="success-content" catchtap="preventBubble">
    <view class="success-icon">✓</view>
    <text class="success-title">提交成功！</text>
    <text class="success-desc">专属顾问将在30分钟内与您联系</text>
    <view class="success-tips">
      <text class="stip">📞 请保持手机畅通</text>
      <text class="stip">📱 关注公众号获取进度</text>
    </view>
    <view class="success-btn" bindtap="closeSuccess"><text>知道了</text></view>
    <view class="success-link" bindtap="goToCases"><text>去浏览案例 →</text></view>
  </view>
</view>