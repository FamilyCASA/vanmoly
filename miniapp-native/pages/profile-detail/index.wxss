/* 个人资料 */
.page { background: #0a0a1a; min-height: 100vh; padding-bottom: 120rpx; }
.avatar-section { display: flex; align-items: center; gap: 24rpx; padding: 40rpx 32rpx; background: #1a1a2e; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.avatar-img { width: 120rpx; height: 120rpx; border-radius: 50%; border: 3rpx solid rgba(212,175,55,0.3); }
.avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: linear-gradient(135deg, #D4AF37, #B8962E); display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #0a0a1a; font-weight: 700; }
.avatar-action { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.avatar-action text { font-size: 28rpx; color: rgba(255,255,255,0.7); }
.avatar-action .arrow { color: #606080; }
.form-group { margin: 24rpx; background: #1a1a2e; border-radius: 16rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,0.06); }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.form-item:last-child { border-bottom: none; }
.fi-label { font-size: 28rpx; color: rgba(255,255,255,0.7); width: 160rpx; flex-shrink: 0; }
.fi-right { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 12rpx; }
.fi-input { font-size: 28rpx; color: #fff; text-align: right; flex: 1; }
.fi-value { font-size: 28rpx; color: #fff; }
.fi-placeholder { font-size: 28rpx; color: rgba(255,255,255,0.3); }
.fi-btn { padding: 8rpx 20rpx; background: rgba(212,175,55,0.15); border-radius: 20rpx; }
.fi-btn text { font-size: 24rpx; color: #D4AF37; }
.arrow { font-size: 32rpx; color: #606080; font-weight: 300; }
.save-btn { margin: 40rpx 32rpx; padding: 28rpx 0; background: #D4AF37; border-radius: 32rpx; text-align: center; }
.save-btn text { font-size: 30rpx; color: #0a0a1a; font-weight: 600; }