/* 产品中心页面 */
.products-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-header {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #fff;
  gap: 12px;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 20px;
  padding: 8px 16px;
}

.search-icon {
  font-size: 16px;
  margin-right: 8px;
  color: #999;
}

.search-bar input {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.search-bar input::placeholder {
  color: #999;
}

.clear-icon {
  font-size: 18px;
  color: #999;
  padding: 0 4px;
}

.selection-entry {
  position: relative;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  font-size: 22px;
}

.selection-badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  background: #8B5A2B;
  color: #fff;
  font-size: 11px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 分类导航 */
.category-nav {
  background: #fff;
  padding: 0 16px 12px;
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 8px 16px;
  margin-right: 8px;
  background: #f5f5f5;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
  transition: all 0.2s;
}

.category-item.active {
  background: #8B5A2B;
  color: #fff;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12px 16px;
  background: #fff;
  border-top: 1px solid #f0f0f0;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: #666;
  padding: 4px 8px;
}

.filter-item.active {
  color: #8B5A2B;
  font-weight: 500;
}

.sort-arrow {
  font-size: 10px;
}

.filter-icon {
  font-size: 12px;
}

/* 产品列表 */
.products-list {
  flex: 1;
  padding: 12px;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.product-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.product-image-wrapper {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
}

.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transition: opacity 0.3s;
}

.product-image.main {
  opacity: 1;
}

.product-image.sub {
  opacity: 0;
}

.product-card:active .product-image.main {
  opacity: 0;
}

.product-card:active .product-image.sub {
  opacity: 1;
}

.quick-add {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 50px;
  height: 50px;
  background: rgba(139, 90, 43, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.product-card:active .quick-add {
  opacity: 1;
}

.add-icon {
  font-size: 24px;
  color: #fff;
}

.product-info {
  padding: 12px;
}

.product-brand {
  display: block;
  font-size: 11px;
  color: #999;
  margin-bottom: 4px;
}

.product-name {
  display: block;
  font-size: 13px;
  color: #333;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.product-price {
  font-size: 15px;
  font-weight: 600;
  color: #8B5A2B;
}

.product-original {
  font-size: 12px;
  color: #999;
  text-decoration: line-through;
}

/* 加载状态 */
.load-more,
.no-more {
  text-align: center;
  padding: 20px;
  font-size: 13px;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: #666;
  margin-bottom: 8px;
}

.empty-tip {
  font-size: 13px;
  color: #999;
}

/* 筛选弹窗 */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.filter-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.filter-content {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 80%;
  max-width: 320px;
  background: #fff;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s;
}

.filter-modal.show .filter-content {
  transform: translateX(0);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.filter-title {
  font-size: 17px;
  font-weight: 600;
}

.filter-close {
  font-size: 24px;
  color: #999;
}

.filter-body {
  flex: 1;
  padding: 20px;
}

.filter-section {
  margin-bottom: 24px;
}

.section-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 12px;
}

.price-range {
  display: flex;
  align-items: center;
  gap: 12px;
}

.price-range input {
  flex: 1;
  padding: 10px 12px;
  background: #f5f5f5;
  border-radius: 6px;
  font-size: 14px;
}

.range-separator {
  color: #999;
}

.brand-list,
.style-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.brand-item,
.style-item {
  padding: 8px 16px;
  background: #f5f5f5;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.brand-item.selected,
.style-item.selected {
  background: #8B5A2B;
  color: #fff;
}

.filter-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid #f0f0f0;
}

.btn-reset {
  flex: 1;
  padding: 12px 24px;
  background: #f5f5f5;
  border: none;
  border-radius: 20px;
  font-size: 14px;
  color: #666;
}

.btn-confirm {
  flex: 1;
  padding: 12px 24px;
  background: #8B5A2B;
  border: none;
  border-radius: 20px;
  font-size: 14px;
  color: #fff;
}

/* 成功提示 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  background: rgba(0, 0, 0, 0.8);
  padding: 20px 32px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s;
  z-index: 2000;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.toast-icon {
  font-size: 28px;
  color: #07c160;
}

.toast-text {
  font-size: 14px;
  color: #fff;
}
