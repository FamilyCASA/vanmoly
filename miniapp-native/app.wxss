/* 梵木里品牌色系 - 从V3.0设计文档提取 */
:root {
  --primary: #8B4513;      /* 原木棕 - 品牌主色 */
  --primary-light: #A0522D; /* 浅原木 */
  --primary-dark: #654321;  /* 深原木 */
  --accent: #D2691E;       /* 巧克力色 - 强调 */
  --gold: #DAA520;         /* 金色 - 高端感 */
  --bg: #f5f5f5;           /* 背景灰 */
  --card-bg: #ffffff;       /* 卡片白 */
  --text: #333333;          /* 主文字 */
  --text-secondary: #666666; /* 次要文字 */
  --text-light: #999999;    /* 辅助文字 */
  --border: #e5e5e5;        /* 边框 */
  --success: #52c41a;       /* 成功绿 */
  --warning: #faad14;       /* 警告黄 */
  --error: #f5222d;         /* 错误红 */
}

/* 全局样式 */
page {
  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 容器 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.2);
}

.btn-gold {
  background: linear-gradient(135deg, var(--gold) 0%, #B8860B 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(218, 165, 32, 0.3);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: rgba(139, 69, 19, 0.1);
  color: var(--primary);
}

.tag-gold {
  background: rgba(218, 165, 32, 0.1);
  color: #B8860B;
}

/* 文字样式 */
.text-primary { color: var(--primary); }
.text-gold { color: var(--gold); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }

.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; font-weight: 600; }
.text-2xl { font-size: 48rpx; font-weight: 700; }

/* 浮动按钮 - 留资抓手 */
.float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 160rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.4);
  z-index: 999;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 底部留资栏 */
.lead-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 弹性布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.ml-10 { margin-left: 10rpx; }

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}