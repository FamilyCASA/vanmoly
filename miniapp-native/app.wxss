/* ============================================
   全局样式 - 暗黑深空风格 (Dark Space Theme)
   帝标·设记家 (D&B) Designary
   ============================================ */

page {
  background-color: #0a0a1a;
  color: #E8E8E8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 全局文字 */
.text-primary { color: #E8E8E8; }
.text-gold { color: #D4AF37; }
.text-muted { color: #A0A0B8; }
.text-dim { color: #606080; }

/* 通用按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-primary {
  background: #D4AF37;
  color: #0a0a1a;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.85);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}