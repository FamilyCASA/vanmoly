.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.canvas-container {
  position: relative;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin: 20rpx 0;
  overflow: hidden;
}

.signature-canvas {
  width: 100%;
  height: 600rpx;
  background: #ffffff;
}

.canvas-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #999;
  font-size: 32rpx;
  pointer-events: none;
}

.actions {
  display: flex;
  justify-content: space-around;
  margin: 40rpx 0;
}

.btn {
  width: 40%;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.btn-clear {
  background: #f0f0f0;
  color: #666;
}

.btn-save {
  background: linear-gradient(135deg, #8B5A2B 0%, #A0522D 100%);
  color: #ffffff;
}

.preview {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.preview-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 100%;
  height: 300rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}
